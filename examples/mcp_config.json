{
    "mcpServers": {
        "jlfricas": {
            "command": "/usr/local/bin/fricas",
            "args": [
                "-nosman",
                "--mcp"
            ],
            "env": {
                "FRICAS": "/usr/local/lib/fricas/target/x86_64-linux-gnu",
                "FRICAS_ALGEBRA_DIR": "/usr/local/lib/fricas/target/x86_64-linux-gnu/src/algebra/"
            }
        }
    }
}