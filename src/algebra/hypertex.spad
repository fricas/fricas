)abbrev package HDCONN HyperdocConnection
HyperdocConnection() : Exports == Implementation where
  Exports ==> with
      send_line : String -> Void
      end_page : () -> Void
  Implementation ==> add

    send_line_tok ==> 98
    end_page_tok ==> 99

    MENU ==> _$MenuServer$Lisp

    send_int(i) ==> sockSendInt(MENU, i)$Lisp

    send_string(s) ==> sockSendString(MENU, s)$Lisp

    send_line(l : String) : Void ==
        send_int(send_line_tok)
        send_string(l)

    end_page() : Void == send_int(end_page_tok)

)abbrev domain HDASSOC HyperdocAssociationList
HyperdocAssociationList == List(Record(key : Symbol, entry : SExpression))

)abbrev domain HDPAGE HyperdocPage
HyperdocPage() : Exports == Implementation where
  SE ==> SExpression
  LSE ==> List(SE)
  SY ==> Symbol
  ALS ==> HyperdocAssociationList
  ALR ==> Record(key : Symbol, entry : SE)
  PSR ==> Record(var : Symbol, pvar : Symbol)
  Exports ==> with
    new : ALS -> %
    destroy : SY -> Void
    name : % -> Symbol
    add_to : (%, List(SE)) -> Void
    add_to_description : (%, String) -> Void
    add_to_description : (%, List(SE)) -> Void
    get_property_list : % -> ALS
    get_property : (%, SY) -> SE
    set_property : (%, SY, SE) -> Void
    show : % -> Void
    button_on? : (%, SY) -> Boolean
    button_value : (%, SY) -> SY
    input_string : (%, SY) -> Union(String, "failed")
    set_input_string : (%, SY, String) -> Void
  Implementation ==> add

    import HyperdocConnection

    Rep := Record(name : Symbol, domain_conditions : LSE,
                  variable_alist : ALS, pattern_vars : List(PSR),
                  radio_buttons : ALS, input_areas : ALS,
                  property_list : ALS, page_description : LSE,
                  work_area : List(String))

    name(page : %) : Symbol ==
        pr : Rep := page
        pr.name

    new(props : ALS) : % ==
        name : Symbol := GENTEMP()$Lisp
        res : % := [name, [], empty(), empty(), empty(), empty(), props, [],
                    []]$Rep
        SET(name, res)$Lisp
        lst : List(SY) := cons(name, _$activePageList$Lisp)
        SETF(_$activePageList$Lisp, lst)$Lisp
        res

    destroy(name : SY) : Void ==
        member?(name, _$activePageList$Lisp)$List(SY) =>
            SET(name, false)$Lisp
            remove!(name, _$activePageList$Lisp)$List(SY)

    get_property_list(page : %) : ALS ==
        pr : Rep := page
        pr.property_list

    add_to_description(page : %, s : String) : Void ==
        pr : Rep := page
        pr.page_description := cons(convert(s), pr.page_description)

    add_to_description(page : %, l : List(SE)) : Void ==
        pr : Rep := page
        for el in l repeat
            pr.page_description := cons(el, pr.page_description)

    setup_default(page : %, name : Symbol, props : LSE) : Void ==
        pr : Rep := page
        pp := [convert([]), convert([]), convert([])]$List(SE)
        pp := concat(pp, props)
        pr.input_areas := cons([name, convert(pp)], pr.input_areas)

    label_error_msg : (%, Symbol) -> Union(SE, "failed")
    hd_assoc : (Symbol, ALS) -> Union(ALR, "failed")

    get_property(page : %, name : SY) : SE ==
        pr : Rep := page
        props := pr.property_list
        u1 := hd_assoc(name, props)
        u1 case "failed" => convert(empty()$LSE)
        ar := u1@ALR
        ar.entry

    set_property(page : %, name : SY, val : SE) : Void ==
        pr : Rep := page
        props := pr.property_list
        u1 := hd_assoc(name, props)
        u1 case "failed" =>
            pr.property_list := cons([name, val]$ALR, props)
        ar := u1@ALR
        ar.entry := val

    input_string(page : %, name : SY) : Union(String, "failed") ==
        pr : Rep := page
        alr := hd_assoc(name, pr.input_areas)
        alr case "failed" => "failed"
        null?(ae := alr.entry) => "failed"
        sv := car(alr.entry)
        string?(sv) => string(sv)
        "failed"

    set_input_string(page : %, name : SY, s : String) : Void ==
        pr : Rep := page
        alr := hd_assoc(name, pr.input_areas)
        alr case "failed" => void()
        ae := destruct(alr.entry)
        ae(1) := convert(s)

    button_on?(page : %, name : SY) : Boolean ==
        pr : Rep := page
        alr := hd_assoc(name, pr.input_areas)
        alr case "failed" => false
        null?(ae := alr.entry) => false
        bv := car(alr.entry)
        string?(bv) and string(bv) = " t"

    button_value(page : %, name : SY) : SY ==
        pr : Rep := page
        alr := hd_assoc(name, pr.radio_buttons)
        alr case "failed" =>
            error "button_value: button group does not exist"
        null?(ae := alr.entry) or not(list?(ae)) =>
            error "button_value: button group should be a list"
        sl := destruct(ae) pretend List(SY)
        for s in sl repeat
            button_on?(page, s) => return s
        error "button_value: no button on!"

    process_add : (%, LSE) -> Void

    process_add1(page : %, item : SE) : Void ==
        list?(item) => process_add(page, destruct(item))

    is_symbol(se : SE, sym : SY) : Boolean ==
        symbol?(se) and symbol(se) = sym

    pattern_substitution_list(cl : List(SE)) : List(PSR) ==
        -- print(message("pattern_substitution_list")$OutputForm)$OutputForm
        res : List(PSR) := []
        pat_vars : List(SY) := _$PatternVariableList$Lisp
        for c in cl repeat
            not(list?(c)) => iterate
            cl1 := destruct(c)
            -- print(cl1::OutputForm)$OutputForm
            #cl1 ~= 3 => iterate
            op := first(cl1)
            -- print(op::OutputForm)$OutputForm
            pv := first(rest(cl1))
            if is_symbol(op, 'isDomain) or is_symbol(op, 'ofCategory) or
               is_symbol(op, 'Satisfies) then
                if not(pv = _$EmptyMode$Lisp) then
                    res := cons([symbol(pv), first(pat_vars)], res)
                pat_vars := rest(pat_vars)
        -- print(res::OutputForm)$OutputForm
        res

    substitute_pvars(cl : LSE, pat_sl : List(PSR)) : LSE ==
        for sr in pat_sl repeat
            cl := substitute(sr.pvar, sr.var, cl)$Lisp
        cl

    get_vars(pat : SE) : List(SY) ==
        res : List(SY) := []
        not(list?(pat)) => res
        for p1 in rest(destruct(pat)) repeat
            if symbol?(p1) and member?(s1 := symbol(p1),
                                       _$PatternVariableList$Lisp) then
                res := cons(s1, res)
        reverse!(res)

    compute_conds(page : %, v1 : SY) : SE ==
        res : LSE := []
        pvars : List(SY) := [v1]
        for c1 in page.domain_conditions repeat
            not(list?(c1)) => iterate
            cl1 := destruct(c1)
            not(#cl1 = 3) => iterate
            cl1 := rest(cl1)
            pv := first(cl1)
            if member?(symbol(pv), pvars) then
                res := cons(c1, res)
                pat := first(rest(cl1))
                pvars := concat!(pvars, get_vars(pat))
        convert(reverse!(res))

    compute_variable_alist(page : %, pat_sl : List(PSR)) : ALS ==
        res : ALS := empty()
        for sr in pat_sl repeat
            v1 := sr.pvar
            res := cons([v1, compute_conds(page, v1)], res)
        reverse!(res)

    process_domain_conditions(page : %, cl : LSE) : Void ==
        pat_sl := pattern_substitution_list(cl)
        page.pattern_vars := pat_sl
        page.domain_conditions := substitute_pvars(cl, pat_sl)
        page.variable_alist := compute_variable_alist(page, pat_sl)

    button_names(l : LSE) : LSE == [destruct(el)(3) for el in l]

    process_radio_buttons(page : %, l : List(SE)) : Void ==
        pr : Rep := page
        group_name := symbol(first(l))
        buttons := rest(l)
        pr.radio_buttons := cons([group_name, convert(button_names(buttons))],
                                 pr.radio_buttons)
        default : String := "1"
        for el in buttons repeat
            (message, info, buttonName) := destruct(el)
            button_name := symbol(buttonName)
            if hd_assoc(button_name, pr.input_areas) case "failed" then
                setup_default(page, button_name,
                              [convert('button), convert(default)])
                default := "0"
            process_add1(page, message)
            process_add1(page, info)

    process_input_string1(page : %, l1 : LSE) : Void ==
            pr : Rep := page
            (n_char, default, name_e, type) := first(l1, 4)
            name := symbol(name_e)
            filter : SE := convert(rest(l1, 4))
            if hd_assoc(name, pr.input_areas) case "failed" then
                setup_default(page, name,
                              [convert('string), default, type, filter])
            if label_error_msg(page, name) case SE then
                error "htpLabelErrorMsg unimplemented"

    process_input_strings(page : %, l : List(SE)) : Void ==
        pr : Rep := page
        ia := pr.input_areas
        for el in l repeat
            l1 := destruct(el)
            (mess1, mess2) := first(l1, 2)
            process_input_string1(page, rest(l1, 2))
            process_add1(page, mess1)
            process_add1(page, mess2)

    process_bc_buttons(page : %, l : List(SE)) : Void ==
        pr : Rep := page
        ia := pr.input_areas
        for el in l repeat
            l1 := destruct(el)
            default_val := first(l1)
            name := symbol(second(l1))
            s_res := hd_assoc(name, ia)
            if s_res case "failed" then
                setup_default(page, name, [convert('button), default_val])

    process_bc_strings(page : %, l : List(SE)) : Void ==
        pr : Rep := page
        for el in l repeat
            l1 := destruct(el)
            process_input_string1(page, l1)

    process_add(page : %, l : List(SE)) : Void ==
        for el in l repeat
            atom?(el) => iterate
            l1 := destruct(el)
            op := symbol(first(l1))
            args := rest(l1)
            op = 'radioButtons or op = 'bcRadioButtons =>
                process_radio_buttons(page, args)
            op = 'inputStrings => process_input_strings(page, args)
            op = 'domainConditions =>
                process_domain_conditions(page, args)
            op = 'bcButtons => process_bc_buttons(page, args)
            op = 'bcStrings => process_bc_strings(page, args)

    add_to(page : %, l : List(SE)) : Void ==
        add_to_description(page, l)
        process_add(page, l)

    label_error_msg(page : %, name : Symbol) : Union(SE, "failed") ==
        pr : Rep := page
        alr := hd_assoc(name, pr.input_areas)
        alr case "failed" => "failed"
        res := destruct(alr.entry)(3)
        null?(res) => "failed"
        res

    label_input_string(page : %, name : Symbol) : Union(String, "failed") ==
        pr : Rep := page
        alr := hd_assoc(name, pr.input_areas)
        alr case "failed" => "failed"
        s := destruct(alr.entry)(1)
        string?(s) => string(s)
        "failed"

    label_default(page : %, name : Symbol) : SE ==
        pr : Rep := page
        mu := label_input_string(page, name)
        mu case String =>
            ms := mu::String
            ms = "t" => convert(1)
            ms = "nil" => convert(0)
            convert(ms)
        alr := hd_assoc(name, pr.input_areas)
        alr case "failed" => convert([])
        destruct(alr.entry)(5)

    render_as_string(se : SE) : String ==
        string?(se) => string(se)
        symbol?(se) =>
            sy := symbol(se)
            sy = "%"::Symbol => "\%"
            string(sy)
        integer?(se) => convert(integer(se))
        PRETTYPRINT(se)$Lisp
        error "render_as_string: unhandled item"

    LFun2 ==> FiniteLinearAggregateFunctions2(SE, LSE, String, List(String))

    render_ls(page : %, ls : List(String)) : Void ==
        pr : Rep := page
        for s in ls repeat
            pr.work_area := cons(s, pr.work_area)

    render1s(page : %, s : String) : Void ==
        pr : Rep := page
        pr.work_area := cons(s, pr.work_area)

    render_l1(page : %, l1 : LSE) : Void ==
        pr : Rep := page
        for el in l1 repeat
            pr.work_area := cons(render_as_string(el), pr.work_area)

    render1(page : %, s : SE) : Void ==
        pr : Rep := page
        list?(s) => render_l1(page, destruct(s))
        pr.work_area := cons(render_as_string(s), pr.work_area)

    render_page : (%, List(SE)) -> Void

    render_item(page : %, item : SE) : Void ==
        atom?(item) => render1(page, item)
        render_page(page, destruct(item))

    split_options(links : SE) : Record(links : LSE, options : LSE) ==
        l1 := destruct(links)
        ll : LSE := []
        lo : LSE := []
        was_options : Boolean := false
        for el in l1 repeat
            was_options => lo := cons(el, lo)
            symbol?(el) and symbol(el) = 'options => was_options := true
            ll := cons(el, ll)
        [reverse!(ll), reverse!(lo)]

    trim_options(links : SE) : LSE ==
        l1 := destruct(links)
        ll : LSE := []
        for el in l1 repeat
            symbol?(el) and symbol(el) = 'options => break
            ll := cons(el, ll)
        reverse!(ll)

    render_page : (%, List(SE)) -> Void

    lRSE ==> List(Record(key : Symbol, entry : SE))

    render_button(page : %, link : String, message : SE, fn : String) : Void ==
        render_ls(page, [link, "{"])
        render1(page, message)
        render_ls(page, ["}{(|htDoneButton| '|", fn, "| (PROGN "])
        pr : Rep := page
        name := string(pr.name)
        for en in entries(pr.input_areas)@lRSE repeat
            el := destruct(en.entry)
            id := string(en.key)
            type := symbol(el(4))
            render_ls(page, ["(|htpSetLabelInputString| ", name, " '|",
                      id, "| "])
            if type = 'string then
                render1s(page, "_"\stringvalue{")
            else
                render1s(page, "_"\boxvalue{")
            render_ls(page, [id, "}_")"])
        render_ls(page, [" ", name, "))}"])

    render_link_button(page : %, link : String, ld : SE, items? : Boolean
                      ) : Void ==
            l1 := destruct(ld)
            (message, info, func) := first(l1, 3)
            val := rest(l1, 3)
            fn : SE := mkCurryFun(func, val)$Lisp
            if items? then
                render1s(page, "\item[")
            render_button(page, link, message, string(symbol(fn)))
            if items? then
                render1s(page, "]\space{}")
            list?(info) => render_page(page, destruct(info))
            render1(page, info)

    render_lisp_links(page : %, arg : SE, memo? : Boolean) : Void ==
        -- error "unimplemented"
        links := trim_options(arg)
        ind_s : String := "5"
        render_ls(page, ["\newline\indent{", ind_s, "}\beginitems"])
        link : String :=
            memo? => "\lispmemolink"
            "\lispdownlink"
        for ld in links repeat
            render_link_button(page, link, ld, true)
        render1s(page, "\enditems\indent{0} ")

    render_bc_links0(page : %, arg : SE, link : String) : Void ==
        links := trim_options(arg)
        for ld in links repeat
            render_link_button(page, link, ld, false)

    render_bc_links(page : %, links : SE) : Void ==
        render_bc_links0(page, links, "\lispdownlink")

    render_bc_lisp_links(page : %, links : SE) : Void ==
        render_bc_links0(page, links, "\lisplink")

    hd_assoc(name : Symbol, al : ALS
            ) : Union(ALR, "failed") ==
)if false
        -- for fails with message:
   >> Apparent user error:
   mode:
   (HyperdocAssociationList)
    must be a list of some mode
)endif
        -- for r in al repeat
        while not(empty?(al)) repeat
            r := first(al)
            name = r.key => return r
            al := rest(al)
        "failed"

    render_input_string1(page : %, mess1 : String, mess2 : String,
                         l1 : LSE, items? : Boolean) : Void ==
            pr : Rep := page
            (n_char, default, name_e, type) := first(l1, 4)
            name := symbol(name_e)
            filter : SE := convert(rest(l1, 4))
            if hd_assoc(name, pr.input_areas) case "failed" then
                setup_default(page, name,
                              [convert('string), default, type, filter])
            if label_error_msg(page, name) case SE then
                error "htpLabelErrorMsg unimplemented"
            if items? then
                render1s(page, "\item ")
                -- render_item(page, mess1)
                render1s(page, mess1)
            render_ls(page, ["\inputstring{", string(name), "}{",
                             convert(integer(n_char))@String, "}{",
                      render_as_string(label_default(page, name)),
                          "} ", mess2])

    render_bc_strings(page : % , arg : SE) : Void ==
        pr : Rep := page
        strings := destruct(arg)
        for el in strings repeat
            render_input_string1(page, "", "", destruct(el), false)

    render_input_strings(page : % , arg : SE) : Void ==
        render1s(page, "\newline\indent{5}\beginitems ")
        strings := destruct(arg)
        for el in strings repeat
            l1 := destruct(el)
            (mess1, mess2) := first(l1, 2)
            render_input_string1(page, string(mess1), string(mess2),
                                 rest(l1, 2), true)
        render1s(page, "\enditems\indent{0}\newline ")

    render_radio_buttons0(page : %, arg : SE, items? : Boolean) : Void ==
        pr : Rep := page
        args := destruct(arg)
        group_name := first(args)
        buttons := rest(args)
        boxes_name := string(GENTEMP()$Lisp)$Symbol
        hd_line : List(String) := ["\radioboxes{", boxes_name,
                    "}{\htbmfile{pick}}{\htbmfile{unpick}}"]
        if items? then
            hd_line := cons("\newline\indent{5}",
                            concat(hd_line, "\beginitems "))
        render_ls(page, hd_line)
        for el in buttons repeat
            (message, info, buttonName) := destruct(el)
            button_name := symbol(buttonName)
            if items? then render1s(page, "\item")
            render_ls(page, ["{\em\radiobox[",
                render_as_string(label_default(page, button_name)),
                  "]{",
                  string(button_name), "}{", boxes_name, "}"])
            if items? then render1s(page, "\space{}")
            render_item(page, message)
            render1s(page, "\space{}}")
            render_item(page, info)
        if items? then render1s(page, "\enditems\indent{0} ")

    render_radio_buttons(page : %, arg : SE) : Void ==
        render_radio_buttons0(page, arg, true)

    render_bc_radio_buttons(page : %, arg : SE) : Void ==
        render_radio_buttons0(page, arg, false)

    render_bc_buttons(page : %, args : SE) : Void ==
        pr : Rep := page
        for arg in destruct(args) repeat
            (default, name_e) := destruct(arg)
            name := symbol(name_e)
            if hd_assoc(name, pr.input_areas) case "failed" then
                setup_default(page, name,
                              [convert('button), default])
            k : SE := label_default(page, name)
            EQUAL(k, 0)$Lisp =>
                render_ls(page, ["\off{", string(name), "}"])
            EQUAL(k, 1)$Lisp =>
                render_ls(page, ["\on{", string(name), "}"])
            render_ls(page, ["\inputbox[", render_as_string(k), "]{",
                string(name), "}{\htbmfile{pick}}{\htbmfile{unpick}}"])

    render_done_button(page : %, arg : SE) : Void ==
        (lab_e, fun_e) := destruct(arg)
        label := string(lab_e)
        fn := string(symbol(fun_e))
        message : String :=
            label = "Continue" => "\ContinueBitmap"
            label = "Push to enter names" or label = "Select to Set Value"
              or label = "Select to Set Values" => "\ControlBitmap{ClickToSet}"
            -- print(label::OutputForm)$OutputForm
            error "render_done_button: unimplemented label"
        render_button(page, "\lispdownlink", convert(message), fn)

    render_doit_button(page : %, arg : SE) : Void ==
        pr : Rep := page
        (lab_e, fun_e) := destruct(arg)
        label := string(lab_e)
        fn := string(fun_e)
        message : String :=
            label = "Do It" => "\DoItBitmap"
            error "unimplemented"
        render_ls(page, ["\newline\vspace{1}\centerline{\lispcommand{",
            message, "}{(|doDoitButton| ", string(pr.name),
              " _"", htEscapeString(fn)$Lisp, "_")}}"])

    render_page_element(page : %, op : Symbol, args : SE) : Void ==
            op = 'text => render1(page, args)
            op = 'bcLinks => render_bc_links(page, args)
            op = 'bcLispLinks => render_bc_lisp_links(page, args)
            op = 'domainConditions => void()
            op = 'bcStrings => render_bc_strings(page, args)
            op = 'bcRadioButtons => render_bc_radio_buttons(page, args)
            op = 'bcButtons => render_bc_buttons(page, args)
            op = 'radioButtons => render_radio_buttons(page, args)
            op = 'lispLinks => render_lisp_links(page, args, false)
            op = 'doneButton => render_done_button(page, args)
            op = 'doitButton => render_doit_button(page, args)
            op = 'inputStrings => render_input_strings(page, args)
            error "unexpected page item"

    render_page(page : %, l : List(SE)) : Void ==
        for el in l repeat
            op : Symbol := 'text
            args : SE :=
                string?(el) => el
                symbol?(el) => convert(string(symbol(el)))
                atom?(el) => error "unexpected atom"
                l1 := destruct(el)
                op := symbol(first(l1))
                convert(rest(l1))
            render_page_element(page, op, args)

    render_page0(page : %) : Void ==
        pr : Rep := page
        pr.work_area := []
        render_page(page, pr.page_description)
        pr.work_area := reverse!(pr.work_area)
        l := concat(pr.work_area)
        send_line(l)
        end_page()

    show(page : %) : Void ==
        pr : Rep := page
        pr.page_description := reverse!(pr.page_description)
        render_page0(page)

)abbrev domain ERRIND ErrorIndicator
++ Author: Waldek Hebisch
++ Description: Error indicator used by BrowserInformation.
ErrorIndicator : Join(RetractableTo(List(String)),
                      CoercibleTo(OutputForm)) == add
    LS ==> List(String)
    coerce(l : LS) : % == l pretend %
    retract(x : %) : LS == x pretend LS
    retractIfCan(x : %) : Union(LS, "failed") == retract(x)
    coerce(x : %) : OutputForm == coerce(retract(x))$LS

)abbrev package BRINFO BrowserInformation
++ Author: Waldek Hebisch
++ Description: This package makes available information about Spad
++ constructors and operations.
BrowserInformation : Exports == Implementation where
  SE ==> SExpression
  LMA ==> LogicalMatchingAutomaton
  SY ==> Symbol
  Con_form ==> SE
  Cond_rec ==> Record(form : SE, condition : SE)
  Cond_con_lst ==> List(Cond_rec)
  Grp_con_rec ==> Record(grp_tag : SE, constrs : Cond_con_lst)
  Grp_con_lst ==> List(Grp_con_rec)
  Sig_doc ==> Record(signature : SE, condition : SE, origin : SE,
                     documentation : String)
  Op_rec ==> Record(name : SY, sdl : List(Sig_doc))
  Op_lst ==> List(Op_rec)
  Grp_rec ==> Record(grp_tag : SE, ops : Op_lst)
  Grp_lst ==> List(Grp_rec)
  Exp_rec ==> Record(cats : Cond_con_lst, ops : Op_lst)
  Split_rec ==> Record(categories : List(SY), domains : List(SY),
                       packages : List(SY))
  Gen_rec ==> Record(con_info : Split_rec, op_info : Op_lst)
  Err_ind ==> ErrorIndicator
  Con_res ==> Union(Split_rec, Err_ind)
  Gen_res ==> Union(Gen_rec, Err_ind)
  Op_res ==> Union(Op_lst, Err_ind)

  Exports ==> with
     constructor_documentation : SY -> String
       ++ constructor_documentation(n) gives documentation string for
       ++ constructor with name s.  Returns empty string for
       ++ undocumented constructors.
     constructor_form : SY -> SE
       ++ constructor_form(n) gives constructor form, that is
       ++ S-expression (list) with constructor name and argument names
       ++ for constructor with name s.
     constructor_kind : SY -> SY
       ++ constructor_kind(s) gives constructor kind, that is one of
       ++ category, domain, package.
     constructor_name? : SY -> Boolean
       ++ constructor_name?(s) returns true if and only if s is a name
       ++ of existing constructor.
     constructor_signature : (SY) -> SE
       ++ constructor_signature(s) gives constructor signature, that
       ++ is S-expression (list) giving type of constructor and types
       ++ of arguments.
     constructor_signature : (SY, List(SE)) -> SE
       ++ constructor_signature(s, al) gives constructor signature,
       ++ with formal argument symbols replaced by elements of al.
     default_name? : SY -> Boolean
       ++ default_name?(s) returns true if and only if s has format
       ++ of name of a default package, that is name of s ends in
       ++ an ampersand.
     exposed_constructor? : SY -> Boolean
       ++ exposed_constructor?(s) returns true if and only if s is
       ++ a name of an exposed constructor.
     exports : Con_form -> Exp_rec
       ++ exports(c) gives explicit exports of a constructor.
     ancestors : (Con_form, SE) -> Cond_con_lst
       ++ ancestors(cf, df) computes ancestors of a constructor.
       ++ cf is constructor form with formal arguments, df when
       ++ not null provides actual arguments.
     children : (Con_form, SE) -> Cond_con_lst
       ++ children(cf, df) computes childen (that is direct descendants)
       ++ of a category.  cf is constructor form with formal arguments,
       ++ df when not null provides actual arguments.
     descendants : (Con_form, SE) -> Cond_con_lst
       ++ descendants(cf, df) computes descendants of a category.
       ++ cf is constructor form with formal arguments, df when
       ++ not null provides actual arguments.
     domains : (Con_form, SE) -> Cond_con_lst
       ++ domains(cf, df) computes domains of a category.
       ++ cf is constructor form with formal arguments, df when
       ++ not null provides actual arguments.
     parents : Con_form -> Cond_con_lst
       ++ parents(c) gives parents (that is direct ancestors) of a
       ++ constructor c.
     dependents : SY -> List(SY)
       ++ dependents(c) gives dependents (that is constructor that
       ++ use c either in exports or in type of an argument) of a
       ++ constructor c.
     users : SY -> List(SY)
       ++ users(c) gives users (that is constructors that use c
       ++ in its implementation) of a constructor c.
     uses : (SY, SE, SE) -> Cond_con_lst
       ++ uses(cn, cf, df) computes constuctors used by constructor
       ++ with name cn.  cf is constructor form with formal arguments,
       ++ df when not null provides actual arguments.
       ++ Note: for default packages cf is corresponding category form.
     search_path : (SE, SE, None) -> Cond_con_lst
       ++ search_path(cf, df, dv) computes search path of a constructor.
       ++ cf is constructor form with formal arguments, df when
       ++ not null provides actual arguments, dv is domain vector or
       ++ nil.
     operations : (Con_form, SE) -> Op_lst
       ++ operations(cf, df) computes operation list of a constructor.
       ++ cf is constructor form with formal arguments, df when
       ++ not null provides actual arguments.
     simp_ops_conditions : (Op_lst, SE, SE) -> Op_lst
       ++ simp_ops_conditions(ol, cf, df) simplifies conditions of
       ++ operations in ol after arguments in df are substituted for
       ++ arguments in cf.
     all_constructors : () -> Split_rec
       ++ all_constructors() gives list of all constructor names,
       ++ split into categories, domains and packages.
     search_constructors : (String, SY) -> Con_res
       ++ search_constructors(n, t) searches for constructors with
       ++ name matching n.  t may be k (meaning all constructors),
       ++ c, d or p (meaning only categories, domains or packages
       ++ are returned).
     search_operations : String -> Op_res
       ++ search_operations(n) searches for operations with name
       ++ matching n.
     search_operations : ((String, Sig_doc) -> Boolean) -> Op_lst
       ++ search_operations(f) searches for operations such that f(n, s)
       ++ is true where n is name of operation and s gives other info
       ++ about operation.
     search_documentation : String -> Gen_res
       ++ search_documentation(n) searches for constructors and
       ++ operations with documentation string matching n.
     search_general : String -> Gen_res
       ++ search_general(n) searches for constructors and operations
       ++ with name matching n.
     group_by_condition : Cond_con_lst -> Grp_con_lst
       ++ group_by_condition(ol) splits list of constructors with
       ++ conditions depending on their conditions.
     group_by_origin : Op_lst -> Grp_lst
       ++ group_by_origin(ol) splits list of operations depending
       ++ on their origin.
     group_by_condition : Op_lst -> Grp_lst
       ++ group_by_condition(ol) splits list of operations depending
       ++ on their conditions.
     group_by_implementation : (List(SE), Con_form, Op_lst) -> Grp_lst
       ++ group_by_condition(al, df, ol) splits list of operations ol
       ++ depending on their implementation.  ol must be a list of
       ++ operations from a domain with form df, al must fully specify
       ++ operations of the domain.
     search_opl : (String, Op_lst) -> Op_res
       ++ search_opl(n, ol) gives list of operations from ol with
       ++ names matching n.
     convert_pattern : String -> Union(LMA, Err_ind)
       ++ convert_pattern(n) converts search pattern n to an internal
       ++ form used by \spad{do_match}.
     do_match : (LMA, String) -> Boolean
       ++ do_match(p, s) returns true if and only if s matches to
       ++ pattern p.
     filter_ops : (LMA, Op_lst) -> Op_lst
       ++ filter_ops(p, ol) gives list of operations from ol with
       ++ names matching p.
     filter_symbols : (LMA, List(SY)) -> List(SY)
       ++ filter_symbols(p, sl) gives list of symbols from sl with
       ++ names matching p.
     ops_from_exports : () -> Op_lst
       ++ ops_from_exports() gives list of all exported operations
       ++ computed from constructor exports.
     ops_from_libdb : () -> Op_lst
       ++ ops_from_libdb() gives list of all exported operations
       ++ from libdb.
       ++ This operation is present only to check compatibility with
       ++ old code and will be removed in the future.
     search_operations_libdb : String -> Op_res
       ++ search_operations_libdb(n) searches for all operations with
       ++ name matching n using old code.
       ++ This operation is present only to check compatibility with
       ++ old code and will be removed in the future.
     downcase : String -> String
       ++ downcase(s) converts s to lower case.
     sublis_formal : (List(SE), SE) -> SE
       ++ sublis_formal(args, expr) replaces formal variable symbols
       ++ in expr by corresponding elements of args.

  Implementation ==> add

    Fun_rec ==> Record(name : SY, sd : Sig_doc)

    get_db_info(x, y) ==> get_database(x, y)$Lisp

    simp_has(p) ==> simpHasPred(p)$Lisp

    sublis_formal(args : List(SE), expr : SE) : SE ==
        sublisFormal(args, expr)$Lisp

    is_symbol?(se : SE, sym : SY) : Boolean ==
        symbol?(se) and symbol(se) = sym

    try_eval(pred : SE, ancestors : Cond_con_lst) : SE ==
        not(pair?(pred)) => pred
        op := car(pred)
        args := destruct(cdr(pred))
        is_symbol?(op, 'OR) =>
            nargs := [v for arg in args |
                       not(null?(v := try_eval(arg, ancestors)))]
            empty?(nargs) => false pretend SE
            member?(true pretend SE, nargs) => true pretend SE
            #nargs = 1 => first(nargs)
            convert(cons(op, nargs))
        is_symbol?(op, 'AND) =>
            nargs := [v for arg in args |
                      not((v := try_eval(arg, ancestors)) = true pretend SE)]
            empty?(nargs) => true pretend SE
            member?(false pretend SE, nargs) => false pretend SE
            #nargs = 1 => first(nargs)
            convert([op, :nargs])
        is_symbol?(op, 'has) and #args = 2 and is_symbol?(args(1), "%"::SY) =>
            av : SE := assoc(args(2), ancestors)$Lisp
            null?(av) => false pretend SE
            cdr(av) = true pretend SE => true pretend SE
            pred
        pred

    simp_pred(pred : SE, ancestors : Cond_con_lst) : SE ==
        npred : SE := simp_has(pred)
        empty?(ancestors) => npred
        null?(npred) => npred
        npred = true pretend SE => npred
        try_eval(npred, ancestors)

    constructor_signature(conname : SY) : SE ==
        getConstructorSignature(conname)$Lisp

    constructor_signature(conname : SY, args : List(SE)) : SE ==
        sig := constructor_signature(conname)
        get_db_info(conname, 'CONSTRUCTORKIND) = 'category =>
            SUBLISLIS(args, _$TriangleVariableList$Lisp, sig)$Lisp
        sublis_formal(args, sig)

    char_a := char("a")$Character
    char_A := char("A")$Character
    char_Z := char("Z")$Character
    char_lpar := char("(")$Character
    char_star := char("*")$Character
    char_tick := char("`")$Character

    downcase(s : String) : String ==
        res := new(#s, space()$Character)
        shift := ord(char_a) - ord(char_A)
        for i in 1..#s repeat
            c := s(i)
            res(i) :=
                 c >= char_A and c <= char_Z => char(ord(c) + shift)
                 c
        res

    is_error?(se : SE) : Boolean ==
        list?(se) and (l := destruct(se); not(empty?(l)) and
            (e1 := first(l); e1 = convert('error)))

    convert_pattern(pat : String) : Union(LMA, Err_ind) ==
        pu := parse_pattern(pat, true)$LogicalRegularExpressionMatch
        pu case "failed" => (["Invalid pattern"]$List(String))::Err_ind
        pu::LMA

    do_match(pat : LMA, s : String) : Boolean ==
        do_match(pat, downcase(s))$LogicalMatchingAutomaton

    filter_ops(pat : LMA, opl : Op_lst ) : Op_lst ==
        res := []$Op_lst
        for opr in opl repeat
            if do_match(pat, string(opr.name)) then
                res := cons(opr, res)
        reverse!(res)

    search_opl(pat : String, opl : Op_lst) : Op_res ==
        pc := convert_pattern(pat)
        pc case Err_ind => pc@Err_ind
        filter_ops(pc, opl)

    constructor_name?(name : SY) : Boolean ==
        res1 : SE := constructor?(name)$Lisp
        not(null?(res1))

    exposed_constructor?(name : Symbol) : Boolean ==
        res1 : SExpression := isExposedConstructor(name)$Lisp
        not(null?(res1))

    simp_ops_conditions(opl : Op_lst, con_form : SE, dom_form : SE
                       ) : Op_lst ==
        res : Op_lst := []
        cl: List(SE) := cons(con_form, rest(destruct(con_form)))
        dl : List(SE) := cons(dom_form, rest(destruct(dom_form)))
        for opr in opl repeat
            res1 : List(Sig_doc) := []
            for sd in opr.sdl repeat
                r1 : Sig_doc :=
                    sd.condition = (true pretend SE) => sd
                    np : SE := SUBLISLIS(dl, cl, sd.condition)$Lisp
                    np := simp_has(np)
                    null?(np) => iterate
                    [sd.signature, np, sd.origin, sd.documentation]
                res1 := cons(r1, res1)
            if not(empty?(res1)) then
                res := cons([opr.name, reverse!(res1)], res)
        reverse!(res)

    fun_cmp : (Fun_rec, Fun_rec) -> Boolean

    flatten_opll : List(Op_lst) -> List(Fun_rec)

    group_funs : List(Fun_rec) -> Op_lst

    fill_op_tab(dom_form : SE, op_tab : XHashTable(SE, Sig_doc)) : Void ==
        opl := exports(dom_form).ops
        fl := flatten_opll([opl])
        for f1 in fl repeat
            n_sd := f1.sd
            n_sig := convert(cons(convert(f1.name),
                                  destruct(n_sd.signature)))@SE
            key?(n_sig, op_tab) => iterate
            op_tab(n_sig) := [n_sd.signature, true pretend SE,
                              n_sd.origin, n_sd.documentation]$Sig_doc
        cl := parents(dom_form)
        for c1 in cl repeat
            fill_op_tab(c1.form, op_tab)

    fix_ops(ops : List(SE), anc_lst : Cond_con_lst) : List(Fun_rec) ==
        res : List(Fun_rec) := []
        for opr in ops repeat
            name := symbol(car(opr))
            for sig_cond in destruct(cdr(opr)) repeat
                scl := destruct(sig_cond)
                n_sig := first(scl)
                n_cond : SE :=
                    #scl < 3 => true pretend SE
                    scl(3)
                n_cond := simp_pred(n_cond, anc_lst)
                null?(n_cond) => iterate
                sd := [n_sig, n_cond, convert([]), ""]$Sig_doc
                res := cons([name, sd]$Fun_rec, res)
        res

    operations(form : SE, dom_form : SE) : Op_lst ==
        op_tab := empty()$XHashTable(SE, Sig_doc)
        fill_op_tab(dom_form, op_tab)
        op := car(form)
        args := rest(destruct(dom_form))
        ople := sublis_formal(args,
                              get_db_info(op, 'OPERATIONALIST))
        anc_lst := ancestors(form, dom_form)
        fl1 : List(Fun_rec) := fix_ops(destruct(ople), anc_lst)
        fl2 : List(Fun_rec) := []
        for opr in fl1 repeat
            name := opr.name
            o_sd := opr.sd
            sig := o_sd.signature
            n_sig := convert(cons(convert(name), destruct(sig)))@SE
            n_sd := op_tab(n_sig)
            -- A hack to avoid duplicate entries.  Condition field is
            -- taken from o_sd, so we use condition field in n_sd to
            -- store information that given signature was handled.
            null?(n_sd.condition) => iterate
            n_sd.condition := false pretend SE
            sd2 := [sig, o_sd.condition, n_sd.origin, n_sd.documentation
                   ]$Sig_doc
            fl2 := cons([name, sd2]$Fun_rec, fl2)
        fl2 := sort(fun_cmp, fl2)
        group_funs(fl2)

    Gr_rec ==> Record(grp_tag : SE, i : Integer, name : SY, sd : Sig_doc)
    Aux_op_rec ==> Record(i : Integer, name : SY, sd : Sig_doc)

    -- The allowed atoms are symbols, integers and strings.  Lists should
    -- be proper.  Lists are sorted after atoms, to prefer simpler
    -- signatures first.
    sex_order(s1 : SE, s2 : SE) : Boolean ==
        list?(s2) =>
            not(list?(s1)) => true
            sl1 := destruct(s1)
            sl2 := destruct(s2)
            repeat
                empty?(sl1) => return not(empty?(sl2))
                empty?(sl2) => return false
                e1 := first(sl1)
                e2 := first(sl2)
                e1 = e2 =>
                    sl1 := rest(sl1)
                    sl2 := rest(sl2)
                return sex_order(e1, e2)
        list?(s1) => false
        string?(s1) =>
             not(string?(s2)) => true
             string(s1) < string(s2)
        string?(s2) => false
        integer?(s1) =>
             not(integer?(s2)) => true
             integer(s1) < integer(s2)
        integer?(s2) => false
        string(symbol(s1)) < string(symbol(s2))

    gr1_ord(g1 : Gr_rec, g2 : Gr_rec) : Boolean ==
        sex_order(g1.grp_tag, g2.grp_tag)

    gr2_ord(a1 : Aux_op_rec, a2 : Aux_op_rec) : Boolean ==
        a1.i < a2.i

    group_data1(lst : List(Aux_op_rec)) : Op_lst ==
        lst := sort(gr2_ord, lst)
        a0 := first(lst)
        lst := rest(lst)
        on := a0.name
        res1 : List(Sig_doc) := [a0.sd]
        res : Op_lst := []
        for a1 in lst repeat
            on = a1.name =>
                res1 := cons(a1.sd, res1)
            res := cons([on, reverse!(res1)], res)
            on := a1.name
            res1 := [a1.sd]
        res := cons([on, res1], res)
        reverse!(res)

    group_data(grd : List(Gr_rec)) : Grp_lst ==
        empty?(grd) => []
        grd := sort(gr1_ord, grd)
        e1 := first(grd)
        ot := e1.grp_tag
        res1 : List(Aux_op_rec) := [[e1.i, e1.name, e1.sd]$Aux_op_rec]
        res : Grp_lst := []
        for gr in rest(grd) repeat
            t := gr.grp_tag
            r1 := [gr.i, gr.name, gr.sd]$Aux_op_rec
            t = ot =>
                res1 := cons(r1, res1)
            opl1 := group_data1(res1)
            res := cons([ot, opl1]$Grp_rec, res)
            ot := t
            res1 := [r1]
        opl1 := group_data1(res1)
        reverse!(cons([ot, opl1], res))

    group_by_field(opl : Op_lst, field : Sig_doc -> SE) : Grp_lst ==
        grd : List(Gr_rec) := []
        i : Integer := 1
        for opr in opl repeat
            name := opr.name
            for sd in opr.sdl repeat
                r1 := [field(sd), i, name, sd]$Gr_rec
                i := i + 1
                grd := cons(r1, grd)
        group_data(grd)

    group_by_condition(opl : Op_lst) : Grp_lst ==
        group_by_field(opl, sd +-> sd.condition)

    group_by_origin(opl : Op_lst) : Grp_lst ==
        group_by_field(opl, sd +-> sd.origin)

    group_by_implementation(args : List(SE), dom_form : SE, opl : Op_lst
                           ) : Grp_lst ==
        con_name := symbol(car(dom_form))
        dom : None := EVAL(dom_form)$Lisp
        dom_name : SE := ELT(dom, 0$Integer)$Lisp
        pred_lst : List(SE) := get_db_info(con_name, 'PREDICATES)
        grd : List(Gr_rec) := []
        i : Integer := 1
        for opr in opl repeat
            op := opr.name
            for sd in opr.sdl repeat
                sig1 : SE := sublisFormal(cdr(dom_name), sd.signature,
                                          args)$Lisp
                sig_imp : SE := get_op_implementation(op, sig1, sd.condition,
                                    pred_lst, dom, dom_name)$Lisp
                r1 := [sig_imp, i, op, sd]$Gr_rec
                i := i + 1
                grd := cons(r1, grd)
        group_data(grd)

    find_symbol(name : String) : Union(SY, "failed") ==
        find_symbol(name)$Lisp

    get_ops_doc(name : Symbol) : List(SE) ==
        doc : List(SE) := get_db_info(name, 'DOCUMENTATION)
        empty?(doc) => doc
        con_doc := destruct(first(doc))
        e1 := first(con_doc)
        not(symbol(e1) = 'constructor) => doc
        con_doc := destruct(con_doc(2))
        e1 := first(con_doc)
        not(null?(e1)) => doc
        rest(doc)

    Sig_rec ==> Record(signature : SE, condition : SE)
    Op_rec2 ==> Record(name : SY, sigs : List(Sig_rec))

    unpack_sig_cond(r1 : SE) : Sig_rec ==
        [car(r1), cdr(r1)]

    sd_cmp(sd1 : Sig_doc, sd2 : Sig_doc) : Boolean ==
        sig1 := sd1.signature
        sig2 := sd2.signature
        sig1 = sig2 =>
            orig1 := sd1.origin
            orig2 := sd2.origin
            orig1 = orig2 => sex_order(sd1.condition, sd2.condition)
            sex_order(orig1, orig2)
        sex_order(sig1, sig2)

    sdl_cmp(sdl1 : List(Sig_doc), sdl2 : List(Sig_doc)) : Boolean ==
        repeat
            empty?(sdl1) => not(empty?(sdl2))
            empty?(sdl2) => return false
            sd1 := first(sdl1)
            sd2 := first(sdl2)
            sd1 = sd2 =>
                sdl1 := rest(sdl1)
                sdl2 := rest(sdl2)
            return sd_cmp(sd1, sd2)

    opr_cmp(r1 : Op_rec, r2 : Op_rec) : Boolean ==
        n1 := r1.name
        n2 := r2.name
        n1 = n2 => sdl_cmp(r1.sdl, r2.sdl)
        n1 < n2

    sig_cmp(r1 : Sig_rec, r2 : Sig_rec) : Boolean ==
        sig1 := r1.signature
        sig2 := r2.signature
        sig1 = sig2 =>
            sex_order(r1.condition, r2.condition)
        sex_order(sig1, sig2)

    sigs_cmp(l1 : List(Sig_rec), l2 : List(Sig_rec)) : Boolean ==
        repeat
            empty?(l1) => not(empty?(l2))
            empty?(l2) => return false
            r1 := first(l1)
            r2 := first(l2)
            r1 = r2 =>
                l1 := rest(l1)
                l2 := rest(l2)
            return sig_cmp(r1, r2)

    opr2_cmp(r1 : Op_rec2, r2 : Op_rec2) : Boolean ==
        n1 := r1.name
        n2 := r2.name
        n1 = n2 => sigs_cmp(r1.sigs, r2.sigs)
        n1 < n2

    op_name(ne : SE) : SY ==
        symbol?(ne) => symbol(ne)
        integer?(ne) =>
            ni := integer(ne)
            ni = 0 => "0"::SY
            ni = 1 => "1"::SY
            error "Unexpected integer as operation name"
        error "Unexpected operation name"

    convert_opl(opl1 : List(SE)) : List(Op_rec2) ==
        empty?(opl1) => []
        r1 := first(opl1)
        opl1 := rest(opl1)
        oname := op_name(car(r1))
        res1 : List(Sig_rec) := [unpack_sig_cond(cdr(r1))]
        opl : List(Op_rec2) := []
        for r1 in opl1 repeat
            name := op_name(car(r1))
            r2 := unpack_sig_cond(cdr(r1))
            name = oname =>
                res1 := cons(r2, res1)
            opl := cons([oname, reverse!(res1)], opl)
            oname := name
            res1 := [r2]
        opl := cons([oname, reverse!(res1)], opl)
        sort(opr2_cmp, opl)

    convert_doc1(d1 : SE) : SE ==
        symbol?(name := car(d1)) => d1
        new_name : SE :=
            not(list?(name)) or not(null?(cdr(name))) =>
                error "convert_doc1: unexpected name form"
            ns := symbol(car(name))
            ns = "0"::SY or ns = "1"::SY => convert(ns)
            error "convert_doc1: unexpected name form"
        dl := rest(destruct(d1))
        convert(cons(new_name, dl))

    convert_doc(doc : List(SE)) : List(SE) ==
        good? := true
        for d1 in doc while good? repeat
            good? := symbol?(car(d1))
        if not(good?) then
            doc := [convert_doc1(d1) for d1 in doc]
        sort(sex_order, doc)

    add_origin(sigs : List(Sig_rec), form : SE) : List(Sig_doc) ==
        [[sig.signature, sig.condition, form, ""] for sig in sigs]

    merge_doc1(sigs : List(Sig_rec), doc1 : List(SE), form : SE
              ) : List(Sig_doc) ==
        res : List(Sig_doc) := []
        for sig in sigs repeat
            found := false
            r1 : Sig_doc := [sig.signature, sig.condition, form, ""]
            for d1 in doc1 while not(found) repeat
               if car(d1) = sig.signature then
                   r1.documentation := string(car(cdr(d1)))
                   found := true
            res := cons(r1, res)
        reverse!(res)

    is_attribute_doc?(d1 : SE) : Boolean ==
        -- print(message("is_attribute_doc?")$OutputForm)$OutputForm
        sdl := destruct(cdr(d1))
        #sdl = 1 and (sig := car(first(sdl));
                      sig = convert([convert('attribute)$SE]))

    merge_doc(opl1 : List(SE), doc : List(SE), form : SE) : Op_lst ==
        -- print(doc::OutputForm)$OutputForm
        empty?(opl1) => []
        opl2 := convert_opl(opl1)
        res : Op_lst := []
        for r1 in opl2 repeat
            name := r1.name
            sdl : List(Sig_doc) :=
                empty?(doc) => sdl := add_origin(r1.sigs, form)
                d1 := first(doc)
                dname := symbol(car(d1))
                while dname < name repeat
                    -- print(d1::OutputForm)$OutputForm
                    -- not(is_attribute_doc?(d1)) =>
                    --    error "merge_doc: unused documentation 1"
                    doc := rest(doc)
                    empty?(doc) => break
                    d1 := first(doc)
                    dname := symbol(car(d1))
                name = dname =>
                    doc := rest(doc)
                    merge_doc1(r1.sigs, destruct(cdr(d1)), form)
                add_origin(r1.sigs, form)
            res := cons([name, sdl], res)
        -- for d1 in doc repeat
            -- print(d1::OutputForm)$OutputForm
            -- if not(is_attribute_doc?(d1)) then
            --    error "merge_doc: unused documentation 2"
        reverse!(res)

    dependents(c : SY) : List(SY) ==
        lib := open("DEPENDENTS.DAASE"::FileName, "input")$BasicKeyedAccessFile
        l : List(SY) := []
        res := read(lib, string(c), l pretend None)
        close!(lib)
        res pretend List(SY)

    users(c : SY) : List(SY) ==
        lib := open("USERS.DAASE"::FileName, "input")$BasicKeyedAccessFile
        l : List(SY) := []
        res := read(lib, string(c), l pretend None)
        close!(lib)
        res pretend List(SY)

    uses(c : SY, cf : SE, dom : SE) : Cond_con_lst ==
        c_lst : List(SE) := getImports(c)$Lisp
        if not(null?(dom)) then
            con_args := cdr(cf) pretend List(Symbol)
            c_lst := SUBLISLIS(cons(dom, rest(destruct(dom))),
                               cons('%, con_args), c_lst)$Lisp
        [[c, true pretend SE] for c in c_lst]

    search_path(cf : SE, dom_form : SE, dom_vec : None) : Cond_con_lst ==
        dbSearchOrder(cf, dom_form, dom_vec)$Lisp

    exports(c : Con_form) : Exp_rec ==
        con_name := symbol(car(c))
        args := rest(destruct(c))
        r1 : SE := getConstructorExports(constructor_form(con_name), true)$Lisp
        r1 := sublis_formal(args, r1)
        cl := car(r1) pretend Cond_con_lst
        opl1 := destruct(cdr(r1))
        doc := destruct(sublis_formal(args, convert(get_ops_doc(con_name))))
        doc := convert_doc(doc)
        opl := merge_doc(opl1, doc, c)
        [cl, opl]

    con_exports(c : SY) : Exp_rec ==
        cf : SE := constructor_form(c)
        null?(cf) =>
            print(c::OutputForm)$OutputForm
            error "con_exports: not a constructor"
        exports(cf)

    flatten_opll(ll : List(Op_lst)) : List(Fun_rec) ==
        empty?(ll) => []
        res1 : List(Fun_rec) := []
        for l1 in ll repeat
            for r1 in l1 repeat
                name := r1.name
                for sd in r1.sdl repeat
                    res1 := cons([name, sd], res1)
        res1

    fun_cmp(f1 : Fun_rec, f2 : Fun_rec) : Boolean ==
        n1 := f1.name
        n2 := f2.name
        n1 = n2 =>
            sd1 := f1.sd
            sd2 := f2.sd
            sig1 := sd1.signature
            sig2 := sd2.signature
            sig1 = sig2 =>
                orig1 := sd1.origin
                orig2 := sd2.origin
                orig1 = orig2 => sex_order(sd1.condition, sd2.condition)
                sex_order(orig1, orig2)
            sex_order(sig1, sig2)
        -- a hack so that 0 and 1 sort first
        n1 = "0"::SY => true
        n2 = "0"::SY => false
        n1 = "1"::SY => true
        n2 = "1"::SY => false
        n1 < n2

    group_funs(fl : List(Fun_rec)) : Op_lst ==
        res : Op_lst := []
        empty?(fl) => res
        f1 := first(fl)
        oname := f1.name
        sdl := [f1.sd]
        for f1 in rest(fl) repeat
            name := f1.name
            name = oname =>
                sdl := cons(f1.sd, sdl)
            res := cons([oname, reverse!(sdl)], res)
            oname := name
            sdl := [f1.sd]
        res := cons([oname, reverse!(sdl)], res)
        reverse!(res)

    convert_opll(ll : List(Op_lst)) : Op_lst ==
        empty?(ll) => []
        fl := flatten_opll(ll)
        fl := sort(fun_cmp, fl)
        group_funs(fl)

    all_con_names() : List(SY) == allConstructors()$Lisp

    ops_from_exports() : Op_lst ==
        cl : List(SY) := all_con_names()
        cfl : List(SE) := []
        for c in cl repeat
            default_name?(c) => iterate
            cf := constructor_form(c)
            null?(cf) => iterate
            cfl := cons(cf, cfl)
        opll : List(Op_lst) := [exports(cf).ops for cf in cfl]
        convert_opll(opll)

    all_ops : Op_lst := []
    all_ops_initialized := false

    search_operations(pat : String) : Op_res ==
        if not(all_ops_initialized) then
            all_ops := ops_from_exports()
            all_ops_initialized := true
        search_opl(pat, all_ops)

    search_operations(f : (String, Sig_doc) -> Boolean) : Op_lst ==
        res := []$Op_lst
        if not(all_ops_initialized) then
            all_ops := ops_from_exports()
            all_ops_initialized := true
        for opr in all_ops repeat
            res1 := []$List(Sig_doc)
            n1 := string(opr.name)
            for sd in opr.sdl repeat
                if f(n1, sd) then
                    res1 := cons(sd, res1)
            if not(empty?(res1)) then
                res := cons([opr.name, reverse!(res1)], res)
        reverse!(res)

    string_to_integer(s : String) : Union(Integer, "failed") ==
        res : SExpression := string2Integer(s)$Lisp
        null?(res) => "failed"
        integer(res)

    load_docs(fl : List(Fun_rec)) : Void ==
        for f1 in fl repeat
            sd := f1.sd
            ds := sd.documentation
            ds = "" => iterate
            ku := string_to_integer(ds)
            if ku case Integer then
                k := ku@Integer
                ds :=
                    k < 2 => ""
                    dbReadComments(k)$Lisp
                sd.documentation := ds

    ops_from_libdb() : Op_lst ==
        res1 := search_operations_libdb("*")
        res1 case Err_ind => error "ops_from_libdb: search failed"
        opl1 := res1@Op_lst
        fl := flatten_opll([opl1])
        load_docs(fl)
        fl := sort(fun_cmp, fl)
        group_funs(fl)

    constructor_kind(name : SY) : SY ==
        get_db_info(name, 'CONSTRUCTORKIND)

    ancestors(cf : Con_form, dom : SE) : Cond_con_lst ==
        ancestorsOf(cf, dom)$Lisp

    children(cf : Con_form, dom : SE) : Cond_con_lst ==
        c_lst : Cond_con_lst := childrenOf(cf)$Lisp
        c_lst := augmentHasArgs(c_lst, cf)$Lisp
        c_lst

    descendants(cf : Con_form, dom : SE) : Cond_con_lst ==
        c_lst : Cond_con_lst := descendantsOf(cf, dom)$Lisp
        augmentHasArgs(c_lst, cf)$Lisp

    domains2(cf : Con_form, dom : SE) : Cond_con_lst ==
        domainsOf(cf, dom)$Lisp

    filter_doms(ls : Cond_con_lst, cf : Con_form, dom : SE)
                : Cond_con_lst ==
        pair?(cf) and is_symbol?(car(cf), 'CATEGORY) =>
            pl := destruct(cdr(cdr(cf)))
            nl : Cond_con_lst := []
            for p in pl repeat
                nl : Cond_con_lst := []
                for r1 in ls repeat
                    np : SE := quickAnd(p, r1.condition)$Lisp
                    nl := cons([r1.form, np]$Cond_rec, nl)
                ls := nl
            ls
        ls2 := domains2(cf, dom)
        nl : Cond_con_lst := []
        for r2 in ls2 repeat
            form1 := r2.form
            for r1 in ls repeat
                if form1 = r1.form then
                    nl := cons([form1, quickAnd(r1.condition,
                                                r2.condition)$Lisp]$Cond_rec,
                               nl)
                    break
        ls := []
        for r1 in nl repeat
            npred : SE := simp_has(r1.condition)
            null?(npred) => iterate
            ls := cons([r1.form, npred]$Cond_rec, ls)
        ls

    domains_of_join(cf : Con_form, dom : SE) : Cond_con_lst ==
        args := rest(destruct(cf))
        dom_args : List(SE) :=
            null?(dom) => [convert([]) for arg in args]
            rest(destruct(dom))
        res := domains2(first(args), first(dom_args))
        for arg in rest(args) for dom_arg in rest(dom_args) repeat
            res := filter_doms(res, arg, dom_arg)
        res

    domains1(cf : Con_form, dom : SE) : Cond_con_lst ==
        not(pair?(cf)) => domains2(cf, dom)
        op := car(cf)
        is_symbol?(op, 'CATEGORY) => []
        is_symbol?(op, 'Join) => domains_of_join(cf, dom)
        domains2(cf, dom)

    domains(cf : Con_form, dom : SE) : Cond_con_lst ==
        c_lst := domains1(cf, dom)
        augmentHasArgs(c_lst, cf)$Lisp

    parents(cf : Con_form) : Cond_con_lst ==
        symbol?(cf) => parentsOf(cf)$Lisp
        parentsOfForm(cf)$Lisp

    default_name?(n : SY) : Boolean ==
        ns := string(n)
        ns(#ns) = char("&")

    split_constructors(lst : List(SY)) : Split_rec ==
        cats := doms := packs := []$List(SY)
        for n in lst repeat
            default_name?(n) => iterate
            n = 'Category => iterate
            kind := constructor_kind(n)
            kind = 'category => cats := cons(n, cats)
            kind = 'domain => doms := cons(n, doms)
            kind = 'package => packs := cons(n, packs)
            error "split_constructors: Unknown constructor kind"
        cats := reverse!(cats)
        doms := reverse!(doms)
        packs := reverse!(packs)
        [cats, doms, packs]

    all_constructors() : Split_rec ==
        cnl := [cn for cn in all_con_names() | not(default_name?(cn))]
        split_constructors(sort(cnl))

    split_ops(lst : List(String)
             ) : Record(con : List(SY), opl : List(String)) ==
        opl : List(String) := []
        cnl : List(Symbol) := []
        opl : List(String) := []
        for str in lst repeat
            str(1) = char("o") => opl := cons(str, opl)
            k := position(char_tick, str)
            sym := str(2..(k - 1))::SY
            cnl := cons(sym, cnl)
        cnl := reverse!(cnl)
        opl := reverse!(opl)
        [cnl, opl]

    filter_symbols(pc : LMA, sl : List(SY)) : List(SY) ==
        res := []$List(SY)
        for sy in sl repeat
            if do_match(pc, string(sy)) then
                res := cons(sy, res)
        reverse!(res)

    search_constructors(pat : String, tag : Symbol) : Con_res ==
        pc := convert_pattern(pat)
        pc case Err_ind => pc@Err_ind
        cnl := [cn for cn in all_con_names() | not(default_name?(cn))]
        cnl2 := filter_symbols(pc, cnl)
        res1 := split_constructors(sort(cnl2))
        tag = 'k => res1
        tag = 'c => [res1.categories, [], []]
        tag = 'd => [[], res1.domains, []]
        tag = 'p => [[], [], res1.packages]
        error "unimplemented"

    get_conname(form : String) : String ==
        k := position(char_lpar, form)
        k < 1 => form(2..#form)
        form(2..(k - 1))

    constructor_form(name : SY) : SE ==
        getConstructorForm(name)$Lisp

    get_constructor_args(name : Symbol) : List(SExpression) ==
        form := destruct(constructor_form(name))
        rest(form)

    constructor_documentation(name : SY) : String ==
        doc : List(SExpression) := get_db_info(name, 'DOCUMENTATION)
        empty?(doc) => ""
        doc := destruct(first(doc))
        e1 := first(doc)
        not(symbol(e1) = 'constructor) => ""
        doc := destruct(doc(2))
        string(doc(2))

    expand_op_line(l1 : String) : Record(name : SY, opr : Sig_doc) ==
        els : List(String) := dbParts(l1, 7, 1)$Lisp
        (name_s, nargs, xflag, sig_s, origs, pred_s, doc) := els
        name := name_s::SY
        pred := parse(pred_s)$InputForm pretend SE
        if null?(pred) then
            pred := true pretend SE
        sig := (parse(sig_s)$InputForm) pretend SE
        car(sig) ~= convert('Mapping) =>
                    error "expand_op_lines: unexpected signature"
        sig := cdr(sig)
        con_sym := get_conname(origs)::Symbol
        orig_l := cons(convert(con_sym),
                         get_constructor_args(con_sym)
                      )$List(SExpression)
        [name, [sig, pred, convert(orig_l), doc]]

    expand_op_lines(lst : List(String)) : Op_lst ==
        empty?(lst) => []
        lst := sort(lst)
        res : Op_lst := []
        (oname, sig1) := expand_op_line(first(lst))
        lst := rest(lst)
        res1 : List(Sig_doc) := [sig1]
        for l1 in lst repeat
            (name, sig1) := expand_op_line(l1)
            name = oname =>
                res1 := cons(sig1, res1)
            res := cons([oname, reverse!(res1)], res)
            oname := name
            res1 := [sig1]
        res := cons([oname, reverse!(res1)], res)
        reverse!(res)

    search_operations_libdb(pat : String) : Op_res ==
        res1 : List(SExpression) := grepConstruct(pat, 'o)$Lisp
        empty?(res1) => []
        not(STRINGP(first(res1))$Lisp) => rest(res1) pretend Err_ind
        expand_op_lines(res1 pretend List(String))

    add_stars(pat1 : String) : String ==
        pre : String :=
            pat1(1) = char_star => ""
            "*"
        post : String :=
            pat1(#pat1) = char_star => ""
            "*"
        concat([pre, pat1, post])

    search_ops_doc(pc : LMA) : Op_lst ==
        if not(all_ops_initialized) then
            all_ops := ops_from_exports()
            all_ops_initialized := true
        res : List(Fun_rec) := []
        for opr in all_ops repeat
            name := opr.name
            for sd in opr.sdl repeat
                if do_match(pc, sd.documentation) then
                    res := cons([name, sd], res)
        group_funs(reverse!(res))

    search_con_doc(pc : LMA) : Split_rec ==
        cnl := [cn for cn in all_con_names() | not(default_name?(cn))]
        res1 : List(SY) := []
        for cn in cnl repeat
            doc := constructor_documentation(cn)
            if do_match(pc, constructor_documentation(cn)) then
                res1 := cons(cn, res1)
        split_constructors(sort(res1))

    search_documentation(pat : String) : Gen_res ==
        pat = "" => (["Invalid pattern"]$List(String))::Err_ind
        pat := add_stars(pat)
        pcu := convert_pattern(pat)
        pcu case Err_ind => pcu@Err_ind
        pc := pcu::LMA
        cl := search_con_doc(pc)
        opl := search_ops_doc(pc)
        [cl, opl]$Gen_rec

    search_general(pat : String) : Gen_res ==
        cu := search_constructors(pat, 'k)
        cu case Err_ind => cu@Err_ind
        ou := search_operations(pat)
        ou case Err_ind => ou@Err_ind
        [cu@Split_rec, ou@Op_lst]$Gen_rec

)abbrev package HDUTIL HyperdocUtilities
++ Author: Waldek Hebisch
++ Description: This package provides functions converting constructors
++ and predicates to strings for Hyperdoc use.  Constructors and
++ and arguments to constructors may be passed in two forms, either
++ as actual value or formal value which may be not evaluable.
HyperdocUtilities() : Exports == Implementation where
    Exports ==> with
        constructor_to_string : SExpression -> String
          ++ constructor_to_string(c) produces printable string
          ++ representation of constructor with form c.
        condition_to_string : SExpression -> String
          ++ condition_to_string(p) produces printable string
          ++ representation of predicate p.
        con_to_strings : (SExpression, Boolean, List(String)) -> List(String)
          ++ con_to_strings(c, do_link, acc) is equivalent to
          ++ con_to_strings(c, ef, true, do_link, acc) with empty
          ++ ef.
        con_to_strings : (SExpression, SExpression, Boolean, Boolean,
                           List(String)) -> List(String)
          ++ con_to_strings(c, ef, do_args, do_link, acc) produces
          ++ string representation in Hyperdoc format for constructor
          ++ of form c, with evaluated form ef.  Result is prepended
          ++ in reverse order to acc.  If do_args is false then constructor
          ++ arguments are omited.  If do_link is true then constructor
          ++ names produce Hyperdoc links.
        con_to_strings : (String, SExpression, SExpression, Boolean,
                           Boolean, List(String)) -> List(String)
          ++ con_to_strings(n, c, ef, do_args, do_link, acc) is like
          ++ con_to_strings(c, ef, do_args, do_link, acc), but uses
          ++ n as name of the toplevel constructor.
        con_to_strings : (Symbol, List(SExpression)) -> List(String)
          ++ con_to_strings(n, c) produces string representation
          ++ in Hyperdoc format of constructor of form c with name n,
          ++ producing links to arguments.  Output is in normal
          ++ order.
        con_arg_to_strings : (Boolean, Symbol, List(SExpression), SExpression,
                              SExpression, Integer, Boolean, List(String)
                             ) -> List(String)
          ++ con_arg_to_strings(k?, op, lef, f, ef, k, do_link, acc)
          ++ produces string representation in Hyperdoc format of
          ++ argument number k to constructor with name op, appending
          ++ result in reverse order to acc.  If do_link is true then
          ++ constructor names produce Hyperdoc links.  When k? is true
          ++ then the argument is a type and f should be its
          ++ constructor form, otherwise the argument is not
          ++ a type.  For non-type arguments either f or ef
          ++ should give argument value.  ef when not a Lisp NIL should
          ++ be possibly quoted evaluated argument value and in such
          ++ case lef should be list of all possibly quoted evaluated
          ++ arguments to the constructor.
        con_args_to_strings : (Symbol, List(SExpression), List(SExpression),
                               Boolean, List(String)) -> List(String)
          ++ con_args_to_strings(op, lf, lef, do_link, acc) produces
          ++ string representation in Hyperdoc format of arguments to
          ++ constructor with name op, appending result in reverse order
          ++ to acc.  If do_link is true then constructor names produce
          ++ Hyperdoc links.  lf and lef are argument lists, elements of
          ++ lf (lef respectively) will be passed as f (ef respectively)
          ++ to \spad{con_arg_to_strings}.
        predicate_to_strings : (SExpression,  Boolean, List(String)
                               ) -> List(String)
          ++ predicate_to_strings(p, do_link, acc) produces string
          ++ representation in Hyperdoc format of predicate p, appending
          ++ result in reverse order to acc.  If do_link is true then
          ++ constructor names produce Hyperdoc links.
    Implementation ==> add

        get_db_info(x, y) ==> get_database(x, y)$Lisp

        BRI ==> BrowserInformation

        SE ==> SExpression
        SY ==> Symbol

        is_symbol? : (SE, Symbol) -> Boolean

        constructor_to_string(c : SE) : String ==
            concat(reverse!(con_to_strings(c, false, [])))

        con_to_strings(con : SE, do_link : Boolean, acc : List(String)
                      ) : List(String) ==
            con_to_strings(con, convert([]), true, do_link, acc)

        has_to_strings(cl : List(SE), do_link : Boolean,
                       acc : List(String)) : List(String) ==
            (dom, cat) := cl
            acc := con_to_strings(dom, do_link, acc)
            acc := cons(" has ", acc)
            symbol?(cat) =>
                con_to_strings(cat, do_link, acc)
            is_symbol?(car(cat), 'SIGNATURE) =>
                cat := cdr(cat)
                op := car(cat)
                ops : SY :=
                    symbol?(op) => symbol(op)
                    integer?(op) =>
                        n := integer(op)
                        n = 0 => "0"::SY
                        n = 1 => "1"::SY
                        error "unexpeted integer as operation"
                    error "unexpected operation"
                ns := string(ops)
                cat := destruct(cat)(2)
                mt : List(SE) := cons(convert('Mapping), destruct(cat))
                acc := cons(ns, acc)
                acc := cons(" : ", acc)
                con_to_strings(convert(mt), do_link, acc)
            con_to_strings(cat, do_link, acc)

        predicate_list_to_strings(word : String, pl : List(SE),
                                  do_link : Boolean, acc : List(String)
                                 ) : List(String) ==
            first := true
            for p in pl repeat
                if not(first) then
                    acc := concat([" ", word, " "], acc)
                first := false
                acc := predicate_to_strings(p, do_link, acc)
            acc

        predicate_to_strings(p : SE, do_link : Boolean,
                             acc : List(String)) : List(String) ==
            op := symbol(car(p))
            op = 'OR or op = 'or =>
                predicate_list_to_strings("or", destruct(cdr(p)),
                                          do_link, acc)
            op = 'AND or op = 'and =>
                predicate_list_to_strings("and", destruct(cdr(p)),
                                          do_link, acc)
            op = 'NOT or op = 'not =>
                acc := cons(" not ", acc)
                predicate_to_strings(destruct(p)(2), do_link, acc)
            op = 'has =>
                has_to_strings(destruct(cdr(p)), do_link, acc)
            error "predicate_to_strings: unimplemented"

        condition_to_string(p : SE) : String ==
            ls := predicate_to_strings(p, false, [])
            concat(reverse!(ls))

        unquote(x : SE) : SE ==
            null?(x) => x
            list?(x) =>
                xl := destruct(x)
                op1 := first(xl)
                is_symbol?(op1, "QUOTE"::Symbol) => xl(2)
                convert([unquote(x1) for x1 in xl])
            x

        typed_val_to_string1(val : SE, t : SE) : String ==
            o : OutputForm :=
                algCoerceInteractive(val, t, ['OutputForm])$Lisp
            concat(lines(formatExpression(o)$Format1D)$OutputBox)

        typed_val_to_string(val : SE, t_op : Symbol, t_args : List(SE),
                            k : Integer) : String ==
            la := [unquote(t_arg) for t_arg in t_args]
            t_sig := constructor_signature(t_op, la)$BRI
            tal := destruct(cdr(t_sig))
            typed_val_to_string1(val, tal(k))

        cons_list_to(l : List(String), acc : List(String)) : List(String) ==
            for s in l repeat
                acc := cons(s, acc)
            acc

        is_symbol?(se : SE, sy : Symbol) : Boolean ==
            symbol?(se) and symbol(se) = sy

        has_op?(se : SE, sy : Symbol) : Boolean ==
            not(list?(se)) => false
            is_symbol?(car(se), sy)

        list_to_string(ty : SE, l : List(SE)) : String ==
            ty1 := elt(destruct(ty), 2)
            has_op?(ty1, 'Symbol) and every?(symbol?, l) =>
                lss : List(String) := ["["]
                first1 : Boolean := true
                for s1 in l repeat
                    if not(first1) then
                        lss := cons(", ", lss)
                    first1 := false
                    lss := cons(string(symbol(s1)), lss)
                lss := cons("]", lss)
                concat(reverse!(lss))
            PRETTYPRINT(ty)$Lisp
            PRETTYPRINT(l)$Lisp
            error "list_to_string: unexpected form of list"

        con_arg_to_strings(k? : Boolean, op : SY, lef : List(SE),
                           form : SE, ef : SE, k : Integer,
                           do_link : Boolean, acc : List(String)
                          ) : List(String) ==
                k? and list?(form) =>
                    acc := con_to_strings(form, ef, true, do_link, acc)
                s : String :=
                    string?(form) =>
                        concat(["_"", string(form), "_""])
                    not(k?) and not(null?(ef)) =>
                        not(list?(ef)) =>
                            typed_val_to_string(ef, op, lef, k)
                        efl := destruct(ef)
                        op1 := first(efl)
                        is_symbol?(op1, "QUOTE"::Symbol) =>
                            typed_val_to_string(car(cdr(ef)), op, lef, k)
                        -- FIXME: do this in a proper way
                        -- symbol?(op1) and symbol(op1) = "#"::Symbol and

                        -- FIXME
                        PRETTYPRINT(ef)$Lisp
                        error "con_args_to_strings: unexpected argument value1"
                    symbol?(form) =>
                        symbol(form) = "T$"::SY => "T"
                        string(symbol(form))
                    integer?(form) => string(integer(form))
                    sig := rest(destruct(constructor_signature(op)$BRI))
                    k > #sig =>
                        error "con_arg_to_strings: wrong argument number"
                    a_type := elt(sig, k)
                    -- FIXME
                    list?(form) =>
                        fl := destruct(form)
                        op1 := first(fl)
                        is_symbol?(op1, "#"::Symbol) and #fl = 2 =>
                            ls1 := fl(2)
                            symbol?(ls1) =>
                                concat("\# ", string(symbol(ls1)))
                            list?(ls1) =>
                                ls1l := destruct(ls1)
                                not(every?(string?, ls1l)) =>
                                    PRETTYPRINT(form)$Lisp
                                    error "con_args_to_strings: "
                                          "unexpected argument value4"
                                lss : List(String) := ["["]
                                first1 : Boolean := true
                                for s1 in ls1l repeat
                                    if not(first1) then
                                        lss := cons(", ", lss)
                                    first1 := false
                                    lss := cons(string(s1), lss)
                                lss := cons("]", lss)
                                lss := reverse!(lss)
                                concat(cons("\#", lss))
                        is_symbol?(op1, "QUOTE"::Symbol) and #fl = 2 =>
                            ls1 := fl(2)
                            symbol?(ls1) and has_op?(a_type, 'Symbol) =>
                                string(symbol(ls1))
                            has_op?(a_type, 'List) and list?(ls1) =>
                                list_to_string(a_type, destruct(ls1))
                            PRETTYPRINT(form)$Lisp
                            error "con_args_to_strings: "
                                  "unexpected argument value5"
                        has_op?(a_type, 'List) =>
                            list_to_string(a_type, fl)
                        PRETTYPRINT(a_type)$Lisp
                        PRETTYPRINT(form)$Lisp
                        error "con_args_to_strings: unexpected argument value2"
                    PRETTYPRINT(form)$Lisp
                    error "con_args_to_strings: unexpected argument value3"
                acc := cons(s, acc)

        con_args_to_strings(op : Symbol, lf : List(SE), lef : List(SE),
                            do_link : Boolean, acc : List(String)
                           ) : List(String) ==
            co_sig : List(Boolean) :=
                op = 'Mapping or op = 'Union => [true for form in lf]
                rest(get_db_info(op, 'COSIG))
            acc := cons("(", acc)
            first := true
            for k? in co_sig for form in lf for ef in lef for k in 1.. repeat
                if not(first) then acc := cons(", ", acc)
                first := false
                acc := con_arg_to_strings(k?, op, lef, form, ef, k,
                                          do_link, acc)
            cons(")", acc)

        convert_arg(arg : SE) : SE ==
            list?(arg) => arg
            string?(arg) => arg
            arg = convert('%) => arg
            convert([arg])

        con_page_link(label : String, op : Symbol, acc : List(String)
                     ) : List(String) ==
            acc := cons_list_to(["\lispdownlink{", label, "}{"], acc)
            cons_list_to(["(|conPage| '(|", string(op), "|))}"], acc)

        record_args_to_strings(args : List(SE), do_link : Boolean,
                               acc : List(String)) : List(String) ==
            acc := cons("(", acc)
            first := true
            for arg in args repeat
                if not(first) then acc := cons(", ", acc)
                first := false
                (col, lab, type) := destruct(arg)
                acc := cons(string(symbol(lab)), acc)
                acc := cons(" : ", acc)
                acc := con_to_strings(type, do_link, acc)
            cons(")", acc)

        union_args_to_strings(args : List(SE), efa : List(SE),
                              do_link : Boolean, acc : List(String)
                             ) : List(String) ==
            empty?(args) => cons("()", acc)
            a1 := first(args)
            list?(a1) and (l1 := destruct(a1); #l1 = 3 and
                           first(l1) = convert(":"::SY)) =>
                record_args_to_strings(args, do_link, acc)
            args := [convert_arg(arg) for arg in args]
            con_args_to_strings('Union, args, efa, do_link, acc)

        con_to_strings(label : String, form : SE, ef : SE, do_args : Boolean,
                       do_link : Boolean, acc : List(String)
                      ) : List(String) ==
            string?(form) =>
                 s := concat(["_"", string(form), "_""])
                 cons(s, acc)
            symbol?(form) =>
                 form = convert('%) => cons("%", acc)
                 con_to_strings(label, convert([form]), convert([]),
                                do_link, false, acc)
            op := symbol(car(form))
            efa :=
                null?(ef) => [ef for f1 in destruct(cdr(form))]
                destruct(cdr(ef))
            op = 'Mapping =>
                form := cdr(form)
                target := car(form)
                args := [convert_arg(arg) for arg in destruct(cdr(form))]
                acc := con_args_to_strings(op, args, rest(efa), do_link, acc)
                acc := cons("->", acc)
                con_to_strings(convert_arg(target), do_link, acc)
            acc :=
                do_link => con_page_link(label, op, acc)
                cons(label, acc)
            args := destruct(cdr(form))
            op = 'Record =>
                record_args_to_strings(args, do_link, acc)
            op = 'Union =>
                union_args_to_strings(args, efa, do_link, acc)
            op = 'Enumeration =>
                acc := cons("(", acc)
                first := true
                for arg in args repeat
                    if not(first) then acc := cons(", ", acc)
                    first := false
                    acc := cons(string(symbol(arg)), acc)
                acc := cons(")", acc)
            not(empty?(args)) and do_args =>
                con_args_to_strings(op, args, efa, do_link, acc)
            acc

        con_to_strings(form : SE, ef : SE, do_args : Boolean,
                       do_link : Boolean, acc : List(String)
                      ) : List(String) ==
            string?(form) =>
                 s := concat(["_"", string(form), "_""])
                 cons(s, acc)
            symbol?(form) =>
                 form = convert('%) => cons("%", acc)
                 con_to_strings(convert([form]), convert([]), false,
                                do_link, acc)
            op := symbol(car(form))
            con_to_strings(string(op), form, ef, do_args, do_link, acc)

        con_to_strings(name : SY, con : List(SE)) : List(String) ==
            lc := rest(con)
            elc := [convert([])$SE for c1 in lc]
            res1 := con_args_to_strings(name, lc, elc, true, [string(name)])
            reverse!(res1)

)abbrev package HDTOP HyperdocTopPage
HyperdocTopPage() : Exports == Implementation where
    Exports ==> with
        do_search : (String, Symbol, String) -> Void
          ++ do_search(pat, tag, ds) performs search for pat.  tag
          ++ decides where to search.  ds is description which is
          ++ used in headers and messages.
        do_page_fun1 : (HyperdocPage, Symbol, SExpression) -> Void
          ++ do_page_fun1(p, tag, d) performs operation specified
          ++ by tag on behalf of page p using data d.
        do_gen_fun1 : (Symbol, SExpression) -> Void
          ++ do_gen_fun1(tag, d) performs operation specified
          ++ by tag using data d.
    Implementation ==> add

        import HyperdocUtilities

        char_lpar := char("(")$Character
        char_rbrace := char("}")$Character
        char_space := char(" ")$Character
        char_star := char("*")$Character
        char_tick := char("`")$Character
        char_s := char("s")$Character
        char_y := char("y")$Character

        get_db_info(x, y) ==> get_database(x, y)$Lisp

        BRI ==> BrowserInformation

        Err_ind ==> ErrorIndicator

        SE ==> SExpression
        LMA ==> LogicalMatchingAutomaton
        SY ==> Symbol
        Con_from ==> SE
        Cond_rec ==> Record(form : SE, condition : SE)
        Cond_con_lst ==> List(Cond_rec)

        Sig_doc ==> Record(signature : SE, condition : SE, origin : SE,
                     documentation : String)
        Op_rec ==> Record(name : SY, sdl : List(Sig_doc))
        Op_lst ==> List(Op_rec)
        Grp_rec ==> Record(grp_tag : SE, ops : Op_lst)
        Grp_lst ==> List(Grp_rec)

        Split_rec ==> Record(categories : List(SY), domains : List(SY),
                             packages : List(SY))
        Gen_rec ==> Record(con_info : Split_rec, op_info : Op_lst)

        Gen_res ==> Union(Gen_rec, Err_ind)

        Save_rec ==> Record(cur : Gen_rec, save : Gen_rec)

        Con_res ==> Union(Split_rec, Err_ind)

        exposed_only? : Boolean := false

        max_browse_count : Integer := 10
        max_description_count : Integer := 4

        is_symbol? : (SE, SY) -> Boolean

        get_doc_list(page : HyperdocPage) : Save_rec ==
            get_property(page, 'docSearchAlist) pretend Save_rec

        set_doc_list(page : HyperdocPage, lst : Save_rec) : Void ==
            set_property(page, 'docSearchAlist, lst pretend SE)

        get_reg_list(page : HyperdocPage) : Union(Save_rec, "failed") ==
            get_property(page, 'regSearchAlist)
                pretend Union(Save_rec, "failed")

        set_reg_list(page : HyperdocPage, lst : Union(Save_rec, "failed")
                    ) : Void ==
            set_property(page, 'regSearchAlist, lst pretend SE)

        get_con_lst(page : HyperdocPage) : Cond_con_lst ==
            get_property(page, 'cAlist) pretend Cond_con_lst

        set_con_lst(page : HyperdocPage, lst : Cond_con_lst) : Void ==
            set_property(page, 'cAlist, lst pretend SE)

        get_op_lst(page : HyperdocPage) : Op_lst ==
            get_property(page, 'opAlist) pretend Op_lst

        set_op_lst(page : HyperdocPage, lst : Op_lst) : Void ==
            set_property(page, 'opAlist, lst pretend SE)

        get_ops_grd(page : HyperdocPage) : Grp_lst ==
            get_property(page, 'ops_grd) pretend Grp_lst

        set_ops_grd(page : HyperdocPage, lst : Grp_lst) : Void ==
            set_property(page, 'ops_grd, lst pretend SE)

        copy_property_list(l : HyperdocAssociationList
                          ) : HyperdocAssociationList ==
            res : HyperdocAssociationList := empty()
            while not(empty?(l)) repeat
                r1 := copy(first(l))
                l := rest(l)
                res := cons(r1, res)
            reverse!(res)

        add_list_to(page : HyperdocPage, ls : List(String)) : Void ==
            for s in ls repeat
                add_to_description(page, s)

        do_change_indent(page : HyperdocPage, n : Integer,
                         plus2? : Boolean) : Void ==
            sl : List(String) :=
                n > 0 =>
                    plus2? => ["\indent{", convert(n + 2), "}\tab{-2}"]
                    ["\indent{", convert(n), "}\tab{0}"]
                ["\indent{0}\newline{}"]
            add_list_to(page, sl)

        change_indent_plus2(page : HyperdocPage, n : Integer) : Void ==
            do_change_indent(page, n, true)

        change_indent(page : HyperdocPage, n : Integer) : Void ==
            do_change_indent(page, n, false)

        add_title(page : HyperdocPage, title : List(String)) : Void ==
            te : List(SE) :=
                [convert("\begin{page}{"), convert(name(page)),
                 convert("}{")]
            add_to(page, te)
            add_list_to(page, title)
            add_to_description(page, "} ")

        downlink(s : String) : Void ==
            page := new(empty())$HyperdocPage
            add_title(page, ["Downlink page"])
            add_list_to(page, ["\replacepage{", s, "}"])
            show(page)

        error_page2(title : String, d3 : List(String)) : Void ==
            page := new(empty())$HyperdocPage
            add_title(page, [title])
            add_to_description(page, "\beginscroll ")
            add_to_description(page, "\vspace{1}\newline ")
            for de in d3 repeat
                add_to_description(page, de)
            add_to_description(page, "\endscroll")
            show(page)

        error_page(data : Err_ind): Void ==
            ds : List(String) := retract(data)
            error_page2(first(ds), rest(ds))

        star_error() : Void ==
            sd : List(String) := [
                  "\vspace{3}\centerline{{\em *} is not a valid"
                      " search string for a general search}"
                    "\centerline{\em {it would match everything!}}"]
            error_page2("Error", sd)

        is_builtin?(pat : String) : Union(String, "failed") ==
            pat := downcase(pat)$BRI
            pat = "enumeration" => ("DomainEnumeration"::String)
            pat = "mapping" => ("DomainMapping"::String)
            pat = "record" => ("DomainRecord"::String)
            pat = "union" => ("DomainUnion"::String)
            "failed"

        add_op_link0 : (HyperdocPage, SY, String, SY, SE
                       ) -> Void

        emit_query(page : HyperdocPage, text : List(String), fun : SY
                  ) : Void ==
            add_to_description(page, "\vspace{1}\centerline{")
            for t1 in text repeat
                add_to_description(page, t1)
            add_to_description(page, "}\centerline{")
            add_op_link0(page, 'bcLispLinks, "\fbox{Yes}", fun, convert('yes))
            add_to_description(page, "\space{4}\downlink{\fbox{No}}{UpPage}")
            add_to_description(page, "}")

        escape_if_needed : String -> String

        empty_result(kind : String, pat : String, expose : String
                    ) : Void ==
            page := new(empty())$HyperdocPage
            title : List(String) := ["No ", kind, " found"]
            add_title(page, title)
            add_to_description(page, "\beginscroll ")
            l : List(String) := [
                "\vspace{1}\newline\centerline{There is no ", expose,
                  kind, " matching pattern}\newline\centerline{{\em "]
            for s in l repeat
                add_to_description(page, s)
            add_to_description(page, escape_if_needed(pat))
            add_to_description(page, "}}")
            add_to_description(page, "\endscroll ")
            show(page)

        trim_pattern(pat : String) : String ==
            pat := trim(pat, char_space)
            pat = "" => "*"
            pat

        start_table(page : HyperdocPage) : Void ==
            add_to_description(page, "\table{")

        end_table(page : HyperdocPage) : Void ==
            add_to_description(page, "}")

        get_count_str(cnt : Integer) : String ==
            cnt = 0 => "No "
            concat(convert(cnt)@String, " ")

        plural_form(s : String) : String ==
            n := #s
            s(n) = char_y => concat(s(1..(n - 1)), "ies")
            s(n) = char_s => concat(s(1..(n - 1)), "es")
            concat(s, "s")

        menu_button : String := "\menuitemstyle{}"

        add_op_link0(page : HyperdocPage, link : SY, label : String,
                     fun : SY, arg : SE) : Void ==
            l0 : List(SE) := [convert(label), convert(""), convert(fun), arg]
            l : List(SE) := [convert(link), convert(l0)]
            add_to(page, [convert(l)])

        add_con_link1(page : HyperdocPage, link : SY, label : String,
                      op : SY) : Void ==
            add_op_link0(page, link, label, 'dbShowCons, convert(op))

        add_op_link1(page : HyperdocPage, link : SY, label : String,
                     op : SY) : Void ==
            add_op_link0(page, link, label, 'dbShowOps, convert(op))

        add_con_link(page : HyperdocPage, label : String, op : SY
                   ) : Void ==
            add_con_link1(page, 'bcLispLinks, label, op)

        add_op_link(page : HyperdocPage, label : String, op : SY
                   ) : Void ==
            add_op_link1(page, 'bcLispLinks, label, op)

        add_to_op_menu(page : HyperdocPage, inactive? : Boolean,
                       last: Boolean, label : String, op : SY) : Void ==
            if inactive? then
                add_list_to(page, ["{\em ", label, "}"])
            else
                add_op_link(page, label, op)
            if not(last) then
                add_to_description(page, "}{")

        operations_menu(page : HyperdocPage, branch : SY,
                        exposedOnlyIfTrue : Boolean) : Void ==
            set_property(page, 'exclusion, convert(branch))
            con_form := destruct(get_property(page, 'conform))
            op_lst := get_op_lst(page)
            empty? : Boolean := empty?(op_lst)
            one? : Boolean := empty? or (#op_lst = 1 and
                                         #first(op_lst).sdl = 1)
            implementation? := not(null?(get_property(page, 'domname)))
            star? := empty?(con_form)
            start_table(page)
            add_to_description(page, "{")
            add_to_op_menu(page, one? or branch = 'conditions, false,
                           "Conditions", 'conditions)
            add_to_op_menu(page, empty? or branch = 'documentation, false,
                           "Descriptions", 'documentation)
            if one? then
                add_to_description(page, "{\em Filter}")
            else
                f_arg : List(SE) := [convert('dbShowOps), convert('filter)]
                add_op_link0(page, 'bcLinks, "Filter", 'htFilterPage,
                             convert(f_arg))
            add_to_description(page, "}{")
            add_to_op_menu(page, one? or branch = 'names, false,
                           "Names", 'names)
            add_to_op_menu(page, not(implementation?) or
                                 branch = 'implementation, false,
                           "Implementations", 'implementation)
            add_to_op_menu(page, one? or branch = 'origins, false,
                           "Origins", 'origins)
            -- FIXME: also test for presence of parameters
            add_to_op_menu(page, one? or branch = 'parameters, false,
                           "Parameters", 'parameters)
            add_to_op_menu(page, one? or branch = 'signatures, true,
                           "Signatures", 'signatures)
            add_to_description(page, "}")
            if star? or (empty? and exposedOnlyIfTrue) then
                add_to_description(page, "{")
                if exposedOnlyIfTrue then
                    add_op_link1(page, 'bcLinks, "Unexposed Also",
                                  'exposureOff)
                else
                    add_op_link1(page, 'bcLinks, "Exposed Only", 'exposureOn)
                add_to_description(page, "}")
            end_table(page)

        add_to_con_menu(page : HyperdocPage, inactive? : Boolean,
                        last : Boolean, label : String, op : SY) : Void ==
            if inactive? then
                add_list_to(page, ["{\em ", label, "}"])
            else
                add_con_link(page, label, op)
            if not(last) then
                add_to_description(page, "}{")

        constructors_menu(page : HyperdocPage, kind : SY,
                          branch : SY) : Void ==
            set_property(page, 'exclusion, convert(branch))
            con_lst := destruct(get_property(page, 'cAlist))
            empty? : Boolean := empty?(con_lst)
            one? : Boolean := empty? or empty?(rest(con_lst))
            start_table(page)
            add_to_description(page, "{")
            add_to_con_menu(page, one? or branch = 'abbrs, false,
                            "Abbreviations", 'abbrs)
            -- FIXME: handle all true case
            add_to_con_menu(page, one? or branch = 'conditions or
                                  null?(get_property(page, 'conform)),
                            false, "Conditions", 'conditions)
            add_to_con_menu(page, empty? or branch = 'documentation, false,
                            "Descriptions", 'documentation)
            -- FIXME: handle case of one name
            if one? then
                add_to_description(page, "{\em Filter}")
            else
                f_arg : List(SE) := [convert('dbShowCons), convert('filter)]
                add_op_link0(page, 'bcLinks, "Filter", 'htFilterPage,
                             convert(f_arg))
            add_to_description(page, "}{")
            add_to_con_menu(page, one? or branch = 'kinds or
                                  kind ~= 'constructor, false,
                            "Kinds", 'kinds)
            add_to_con_menu(page, one? or branch = 'names, false,
                            "Names", 'names)
            -- FIXME: handle case of no parameters
            add_to_con_menu(page, one? or branch = 'parameters, false,
                            "Parameters", 'parameters)
            if exposed_only? then
                add_con_link1(page, 'bcLinks, "Unexposed Also", 'exposureOff)
            else
                add_con_link1(page, 'bcLinks, "Exposed Only", 'exposureOn)
            add_to_description(page, "}")
            end_table(page)

        exp_con?(c : SE) : Boolean ==
            exposed_constructor?(symbol(first(destruct(c))))$BRI

        mk_fake_sig(s : SY) : SE ==
            sl : List(SE) := [convert(s)]
            cl : List(SE) := [convert('CATEGORY), convert('domain)]
            convert([convert(cl), convert(sl), convert(sl)])

        escape_if_needed(s : String) : String ==
            -- Minimal, but only this caused trouble
            s = "#" => "\#"
            s = "/\" => "/\\"
            s = "\/" => "\\/"
            s

        emit_constructor : (HyperdocPage, SE) -> Void

        parser_op?(op : SE, kind : SY) : Boolean ==
            not(symbol?(op)) => false
            res : SE := GET(op, kind)$Lisp
            not(null?(res))

        is_niladic?(op : SE) : Boolean ==
            not(symbol?(op)) => false
            s1 := symbol(op)
            s1 = "0"::SY or s1 = "1"::SY => true
            res : SE := get_db_info(s1, 'NILADIC)
            not(null?(res))

        emit_star : HyperdocPage -> Void

        arg_to_string(x : SE) : String ==
            symbol?(x) => string(symbol(x))
            PRETTYPRINT(x)$Lisp
            error "arg_to_string: unexpected form of argument"

        add_op_link2(page : HyperdocPage, label : String, arg : SE
                    ) : Void ==
            null?(arg) => add_to_description(page, label)
            add_op_link0(page, 'bcLinks, label, 'dbShowOps, arg)

        display_op_sig(page : HyperdocPage, op : SE,
                   args : List(SE), n : Integer,
                   pred : SE, lnk : SE,
                   unexposed? : Boolean) : Void ==
            arg1 : String :=
                n > 1 => arg_to_string(first(args))
                ""
            ops : String := string(symbol(op))
            ops := escape_if_needed(ops)
            n = 2 and parser_op?(op, 'Nud) =>
                add_op_link2(page, ops, lnk)
                add_list_to(page, [" {\em ", arg1, "}"])
            n = 3 and parser_op?(op, 'Led) =>
                add_list_to(page, [" {\em ", arg1, "}"])
                add_op_link2(page, ops, lnk)
                add_list_to(page, [" {\em ", arg_to_string(args(2)), "}"])
            if unexposed? then
                emit_star(page)
            add_op_link2(page, ops, lnk)
            eq(pred, convert('ASCONST)) or is_niladic?(op) => void()
            add_to_description(page, "(")
            first_time : Boolean := true
            for arg in args repeat
                if not(first_time) then
                    add_to_description(page, ",")
                first_time := false
                add_list_to(page,["{\em ", arg_to_string(arg), "}"])
            add_to_description(page, ")")

        finish_constructor(page : HyperdocPage, conname : SY) : Void ==
            abbr : SE :=
                get_db_info(conname, 'ABBREVIATION)
            if not(null?(abbr)) then
                abr_s := string(symbol(abbr))
                add_to_description(page, "\tab{2}{\em Abbreviation:}")
                change_indent(page, 15)
                add_to_description(page, abr_s)
                change_indent(page, -15)
                add_to_description(page, "\newline{}")
            sf_e : SE := get_db_info(conname, 'SOURCEFILE)
            if not(null?(sf_e)) then
                sf := string(sf_e)
                bsf : String := drop_directory_part(sf)$Lisp
                add_to_description(page, "\tab{2}{\em Source File:}")
                change_indent(page, 15)
                sl : List(String) := ["\unixcommand{", bsf, "}{",
                    "\$FRICAS/lib/SPADEDIT ", sf, " ", string(conname),
                      "}"]
                add_list_to(page, sl)
                change_indent(page, -15)

        display_doc(page : HyperdocPage, doc : String) : Void ==
            add_to_description(page, "\newline\tab{2}{\em Description:}")
            change_indent(page, 15)
            s1 : String := SUBSTITUTE(_$charNewline$Lisp,
                                      _$charFauxNewline$Lisp, doc)$Lisp
            add_to_description(page, s1)
            change_indent(page, -15)

        emit_predicate(page : HyperdocPage, p : SE, form : SE) : Void ==
            ls := predicate_to_strings(p, true, [])
            add_list_to(page, reverse!(ls))

        emit_category_exports(page: HyperdocPage, vals : List(SE)
                             ) : Void ==
            add_to_description(page, ":")
            for val in vals repeat
                add_to_description(page, "\newline{}")
                vl := destruct(val)
                op := symbol(first(vl))
                vl := rest(vl)
                op = 'SIGNATURE =>
                     ope := first(vl)
                     op2 :=
                          symbol?(ope) => symbol(ope)
                          integer?(ope) =>
                              k := integer(ope)
                              k = 0 => "0"::SY
                              k = 1 => "1"::SY
                              error "emit_category_exports: unexpected integer"
                          error "emit_category_exports: unexpected operator"
                     add_to_description(page, escape_if_needed(string(op2)))
                     add_to_description(page, " : ")
                     vl := cons(convert('Mapping), destruct(vl(2)))
                     emit_constructor(page, convert(vl))
                op = 'IF =>
                     error "emit_category_exports: found IF"
                error "emit_category_exports: unexpected construct"

        emit_value(page : HyperdocPage, val : SE, generalSearch? : Boolean,
                   ret? : Boolean, conargs : List(SE),
                   conkind : SE, conlength : Integer, signature : SE
                  ) : Void ==
            null?(val) =>
                error "emit_value: null value"
            val = convert('%) =>
                add_to_description(page, "an element of domain \%")
            symbol?(val) =>
                op := symbol(val)
                add_to_description(page, "an element of domain ")
                if constructor_name?(op)$BRI then
                    emit_constructor(page, convert([val]))
                else
                    add_to_description(page, escape_if_needed(string(op)))
                -- print(val::OutputForm)$OutputForm
                -- error "emit_value: symbol not a constructor name"
            list?(val) =>
                vl := destruct(val)
                op := symbol(first(vl))
                vl := rest(vl)
                op = 'Mapping =>
                    -- target := vl(2)
                    -- source := rest(vl, 2)
                    -- add_to_description(page, a function from ")
                    add_to_description(page, "a function with signature ")
                    emit_constructor(page, val)
                op = 'Category =>
                    empty?(vl) =>
                        add_to_description(page, "a category")
                    error "emit_value: Category with arguments!"
                op = 'Join =>
                    r := last(vl)
                    has_exports? := not(null?(r)) and list?(r) and
                        is_symbol?(car(r), 'CATEGORY)
                    -- cat_cnt : Integer :=
                    --    has_exports? => #vl - 1
                    --    #vl
                    -- add_to_description(page, (cat_cnt < 2 => category
                    -- has_exports? and not(ret?) =>
                    --    error "emit_value: argument with exports"
                    if has_exports? then
                        vl := first(vl, qcoerce(#vl - 1))
                    add_to_description(page, "a domain of ")
                    cw : String := (#vl > 1 => "categories "; "category")
                    add_to_description(page, cw)
                    first := true
                    for v in vl repeat
                        if not(first) then add_to_description(page, ", ")
                        first := false
                        emit_constructor(page, v)
                    if has_exports? then
                        add_to_description(page, " and with explicit exports")
                        if not(ret?) then
                            emit_category_exports(page, rest(destruct(r), 2))
                constructor_name?(op)$BRI =>
                    kind := constructor_kind(op)$BRI
                    iw : String :=
                        kind = 'category => "a domain of category "
                        "an element of domain "
                    add_to_description(page, iw)
                    emit_constructor(page, val)
                member?(op, ['Enumeration, 'Record, 'Union]) =>
                    add_to_description(page, "an element of domain ")
                    emit_constructor(page, val)
                op = 'CATEGORY =>
                    op2 := symbol(first(vl))
                    add_to_description(page, "a ")
                    if op2 = 'domain or op2 = 'package then
                         add_to_description(page, string(op2))
                    else
                         error "emit_value: CATEGORY of strange kind"
                    add_to_description(page, " with explicit exports")
                    not(ret?) =>
                        -- print(val::OutputForm)$OutputForm
                        emit_category_exports(page, rest(vl))
                    -- error "emit_value: CATEGORY as an argument"
                print(val::OutputForm)$OutputForm
                error "emit_value: op not a constructor"
            string?(val) =>
                add_to_description(page, "an element of domain ")
                emit_constructor(page, val)
            print(val::OutputForm)$OutputForm
            error "emit_value: not a list"

        skip_blanks(k : Integer, s : String) : Integer ==
            l := #s
            while k < l and s(k + 1) = char_space repeat k := k + 1
            k

        prefix_match(l : Integer, pref : String, s : String) : Boolean ==
            k := #pref
            #s < k + l => false
            for i in 1..k repeat
                if s(i + l) ~= pref(i) then return false
            true

        op_args_from_doc(op : SY, n : Integer, doc : String
                        ) : Union(List(SY), "failed") ==
            n = 0 => []
            -- print(message("op_args_from_doc")$OutputForm)$OutputForm
            -- print(op::OutputForm)$OutputForm
            -- print(n::OutputForm)$OutputForm
            -- print(doc::OutputForm)$OutputForm
            pref : String := "\spad{"
            not(prefix_match(0, pref, doc)) => "failed"
            -- print(message("prefix_match OK")$OutputForm)$OutputForm
            k := #pref
            l := #doc
            m := position(char_rbrace, doc)
            m < 1 => "failed"
            -- print(doc((k + 1)..(m - 1))::OutputForm)$OutputForm
            pf := parse(doc((k + 1)..(m - 1)))$InputForm pretend SE
            -- print(pf::OutputForm)$OutputForm
            null?(pf) or not(list?(pf)) => "failed"
            pfl := destruct(pf)
            #pfl ~= n + 1 or not(every?(symbol?, pfl)) or
                symbol(first(pfl)) ~= op => "failed"
            rest(pfl) pretend List(SY)

        ias_Rec ==> Record(np : Integer, ep: Integer, fp : Integer,
                           dp : Integer)

        classify_argument(t1 : SE) : SY ==
            list?(t1) =>
                tl := destruct(t1)
                op := first(tl)
                is_symbol?(op, "Integer"::SY) => 'num
                is_symbol?(op, "Mapping"::SY) => 'fun
                kind : SY :=
                    symbol?(op) => get_db_info(op, 'CONSTRUCTORKIND)
                    'domain
                kind = 'category => 'dom
                'elem
            'elem

        sym_from_string(k : Integer, ns : String) : SY ==
            n := #ns
            qr := divide(k, n)
            q := qr.quotient
            ss :=
                s0 := construct([ns(qr.remainder + 1)])$String
                q > 0 => concat(s0, convert(q)@String)
                s0
            ss::SY

        invent_argument_name(t1 : SE, state : ias_Rec) : SY ==
            -- print(message("invent_argument_name")$OutputForm)$OutputForm
            -- print(t1::OutputForm)$OutputForm
            kind : SY := classify_argument(t1)
            kind = 'dom =>
                res := sym_from_string(state.dp, "RSDETABCMNPQUVW")
                state.dp := state.dp + 1
                res
            kind = 'num =>
                res := sym_from_string(state.np, "ijklmn")
                state.np := state.np + 1
                res
            kind = 'fun =>
                res := sym_from_string(state.fp, "fghdeFGH")
                state.fp := state.fp + 1
                res
            res := sym_from_string(state.ep, "xyzuvw")
            state.ep := state.ep + 1
            res

        invent_argument_names(sig : List(SE)) : List(SY) ==
            state := [0, 0, 0, 0]$ias_Rec
            [invent_argument_name(t1, state) for t1 in rest(sig)]

        operation_arguments(op : SY, sig : SE, doc : String) : List(SY) ==
            #sig = 1 => []
            au := op_args_from_doc(op, #sig - 1, doc)
            au case List(SY) => au
            invent_argument_names(destruct(sig))

        fix_T(s : SE) : SE ==
            is_symbol?(s, "T$"::SY) => convert("T"::SY)
            s

        show_op_detail(page : HyperdocPage, kind : String, origin : SE,
                       op : SY, sig : SE, pred : SE, doc : String,
                       i : Integer, only_one : Boolean, sel_fn : SY,
                       unexposed? : Boolean, generalSearch? : Boolean,
                       star? : Reference(Boolean)
                      ) : Void ==
            oform : SE :=
                kind = "constructor" => origin
                cons(op, operation_arguments(op, sig, doc)) pretend SE
            -- print(message("show_op_detail, oform =")$OutputForm)$OutputForm
            -- print(oform::OutputForm)$OutputForm
            op2 := car(oform)
            args := [fix_T(arg) for arg in rest(destruct(oform))]
            if convert(op) ~= op2 then
                BREAK()$Lisp
            conform : SE := get_property(page, 'domname)

            if null?(conform) then
                conform := get_property(page, 'conform)
            if null?(conform) then
                conform := origin

            form_l := destruct(conform)
            conname : SY := symbol(first(form_l))
            conargs := rest(form_l)

            constring : String := constructor_to_string(conform)
            conlength := #constring

            conkind : SE := get_property(page, 'kind)
            if null?(conkind) then
                conkind := convert(string(constructor_kind(conname)$BRI))
            signature : SE := convert([])
            if kind = "operation" then
                signature :=
                    member?(conname, _$Primitives$Lisp) => convert([])
                    constructor_signature(conname)$BRI
                tvarlist : List(SY) :=
                    TAKE(#conargs, _$TriangleVariableList$Lisp)$Lisp
                signature := SUBLISLIS(_$FormalMapVariableList$Lisp,
                                       tvarlist, signature)$Lisp
            add_to_description(page, "\newline")
            if only_one then
                add_to_description(page, menu_button)
            else
                add_op_link0(page, 'bcLinks, menu_button, convert(sel_fn),
                             convert(i))
            add_to_description(page, "\tab{2}")
            n := #sig
            -- print(message("calling display_op_sig")$OutputForm)$OutputForm
            display_op_sig(page, op2, args, n, pred, convert(empty()),
                           unexposed?)
            -- print(message("args, sig =")$OutputForm)$OutputForm
            -- print(args::OutputForm)$OutputForm
            -- print(sig::OutputForm)$OutputForm
            if not(empty?(args)) then
                co_sig : List(Boolean) := get_db_info(op2, 'COSIG)
                if not(empty?(co_sig)) then
                    co_sig := rest(co_sig)
                add_to_description(page, "\newline\tab{2}{\em Arguments:}")
                for arg in args for t in rest(destruct(sig)) repeat
                    change_indent_plus2(page, 15)
                    if not(empty?(co_sig)) and first(co_sig) and
                       not t = convert([convert('Type)]) then
                        arg1 : SE :=
                            only_one => arg
                            convert([arg, convert(i)])
                        add_op_link0(page, 'bcLinks, string(symbol(arg)),
                                     'kArgPage, arg1)
                    else
                        add_list_to(page, ["{\em ", arg_to_string(arg),
                                            "}"])
                    add_to_description(page, ", ")
                    if not(empty?(co_sig)) then
                        co_sig := rest(co_sig)
                    emit_value(page, t, generalSearch?,
                        false, conargs, conkind, conlength, signature)
                    change_indent_plus2(page, -15)
                    add_to_description(page, "\newline")
            add_to_description(page, "\newline\tab{2}{\em Returns:}")
            change_indent_plus2(page, 15)
            emit_value(page, first(destruct(sig)),
                generalSearch?, true, conargs, conkind,
                    conlength, signature)
            change_indent_plus2(page, -15)
            op3 : SE :=
                pair?(origin) => car(origin)
                origin
            if not(null?(origin)) and (generalSearch? or origin ~= conform)
               and op2 ~= op3 then
                add_to_description(page, "\newline\tab{2}{\em Origin:}")
                change_indent(page, 15)
                if not(exp_con?(origin)) then
                    emit_star(page)
                    setref(star?, true)
                emit_constructor(page, origin)
                change_indent(page, -15)
            if not(eq(pred, true pretend SE) or
               eq(pred, convert('ASCONST))) then
                -- print(pred::OutputForm)$OutputForm
                pred := sublis_formal(rest(form_l), pred)$BRI
                cnt := #destruct(pred)
                add_to_description(page, "\newline\tab{2}{\em Conditions:}")
                p : SE := SUBST(conform, '%, pred)$Lisp
                do_change_indent(page, 15, cnt > 1)
                emit_predicate(page, p, conform)
                do_change_indent(page, -15, cnt > 1)
                add_to_description(page, "\newline")
            if doc ~= "" then
                display_doc(page, doc)

        get_cons_form(name : SY) : Cond_rec ==
            form1 := constructor_form(name)$BRI
            [form1, true pretend SE]

        constructor_title(page : HyperdocPage, cnt : Integer, key : SY,
                          kind : SY, exposedOnlyIfTrue : Boolean
                         ) : List(String) ==
            thing : String :=
                thinge := get_property(page, 'thing)
                null?(thinge) => "constructor"
                string(thinge)
            orig := get_property(page, 'domname)
            if null?(orig) then
                orig := get_property(page, 'conform)
            thing = "benefactor" =>
                [convert(cnt), " constructors used by ",
                    constructor_to_string(orig)]
            modifier : List(String) :=
                thing = "argument" =>
                    rank := get_property(page, 'rank)
                    null?(rank) => [""]
                    [" possible ", string(rank), " "]
                kind = 'constructor => [" "]
                [" ", string(kind), " "]
            exposureWord : String :=
                exposedOnlyIfTrue => " exposed "
                ""
            cnt_str := get_count_str(cnt)
            if cnt ~= 1 then
                thing := plural_form(thing)
            modifier := concat(modifier, thing)
            prefix : List(String) :=
                cnt = 1 => cons(cnt_str, modifier)
                concat([cnt_str, exposureWord], modifier)
            orig_part : List(String) :=
                null?(orig) => []
                [" of {\em ", constructor_to_string(orig), "}"]
            res := concat(prefix, orig_part)
            connective : String :=
                member?(key, ['abbrs, 'files, 'kinds]) => " as "
                " with "
            cnt > 0 and member?(key, ['abbrs, 'files, 'parameters,
                                      'conditions]) =>
                view : String :=
                    key = 'abbrs => "abbreviations"
                    string(key)
                concat(res, [" viewed", connective, "{\em ", view, "}"])
            res

        show_cons : (HyperdocPage, SE) -> Void

        count_ops : Op_lst -> Integer

        show_op_names : (HyperdocPage, Op_lst, Reference(Boolean)) -> Void

        display_exported_ops(page : HyperdocPage, lst : Op_lst) : Void ==
            cnt := #lst
            cnt = 0 => void()
            total := count_ops(lst)
            set_op_lst(page, lst)
            add_to_description(page, "\indent{0}")
            add_op_link1(page, 'bcLinks, menu_button, 'names)
            add_to_description(page, "\tab{3}")
            if cnt ~= total then
                if cnt = 1 then
                    add_to_description(page, "1 name for ")
                else
                    add_list_to(page, [convert(cnt)@String, " names for "])
            if total > 1 then
                add_list_to(page, [convert(total)@String, " operations "
                                   "are explicitly exported:"])
            else
                add_to_description(page,
                                   "1 operation is explicitly exported:")
            star? := ref(false)$Reference(Boolean)
            show_op_names(page, lst, star?)

        get_constructor_kind : SY -> SY

        get_input_area : (HyperdocPage, Integer) -> List(String)

        get_evalable_constructor_form(page : HyperdocPage, name : SY
                                     ) : Union(SE, Err_ind) ==
            -- print(message("get_evalable_constructor_form"
            --             )$OutputForm)$OutputForm
            kind := get_constructor_kind(name)
            form := constructor_form(name)$BRI
            set_property(page, 'domname, convert([]))
            -- kind = 'category => convert([])
            nargs : Integer := #form - 1
            in_args := get_input_area(page, nargs)
            set_property(page, 'inputAreaList, in_args pretend SE)
            n : Integer := 0
            for arg in in_args repeat
                arg = "" => iterate
                n := n + 1
            n = 0 and 0 < nargs => convert([])@SE
            0 < n and n < nargs =>
                el : List(String) := ["Error",
                    "\centerline{You gave values for only {\em ", convert(n),
                        " } of the {\em ", convert(nargs),
                      "}}\centerline{parameters of {\sf ", string(name),
                  "}}\vspace{1}\centerline{Please enter either {\em all}"
                    " or {\em none} of the type parameters}"]
                el::Err_ind
            args : String :=
                arg_l : List(String) := ["("]
                first := true
                for arg in in_args repeat
                    if not(first) then
                        arg_l := cons(",", arg_l)
                    first := false
                    arg_l := cons(arg, arg_l)
                arg_l := cons(")", arg_l)
                concat(reverse!(arg_l))
            -- print(message("args =")$OutputForm)$OutputForm
            -- print(args::OutputForm)$OutputForm
            res : Union(SE, "failed") :=
                make_domain_form(string(kind), string(name), args)$Lisp
            res case "failed" =>
                s1 := "\centerline{You gave an invalid type:}\newline"
                      "\centerline{{\sf "
                el := ["Error", s1, concat(string(name), args), "}}"
                      ]$List(String)
                el::Err_ind
            res

        do_related(page : HyperdocPage, what : String,
                   fun : (SE, SE) -> Cond_con_lst,
                   cat_descendants? : Boolean) : Void ==
            con_form := get_property(page, 'conform)
            name := symbol(car(con_form))
            domu := get_evalable_constructor_form(page, name)
            domu case Err_ind => error_page(domu)
            domname : SE := domu
            if not(null?(domname)) and not(cat_descendants?) then
                set_property(page, 'domname, domname)
            c_lst : Cond_con_lst := fun(con_form, domname)
            c_lst := mySort(c_lst)$Lisp
            set_con_lst(page, c_lst)
            set_property(page, 'thing, convert(what))
            show_cons(page, 'names)

        ancestors_page(page : HyperdocPage) : Void ==
            do_related(page, "ancestor", ancestors$BRI, false)

        descendents_page(page : HyperdocPage) : Void ==
            do_related(page, "descendant", descendants$BRI, true)

        domains_page(page : HyperdocPage) : Void ==
            do_related(page, "descendant", domains$BRI, false)

        children_page(page : HyperdocPage) : Void ==
            do_related(page, "children", children$BRI, false)

        dependents_page(page : HyperdocPage) : Void ==
            conform := get_property(page, 'conform)
            name := symbol(car(conform))
            kind := get_constructor_kind(name)
            d_lst : List(SY) := dependents(name)$BRI
            c_lst := [get_cons_form(d) for d in d_lst]
            set_con_lst(page, c_lst)
            set_property(page, 'thing, convert("dependent"))
            show_cons(page, 'names)

        uses_page(page : HyperdocPage) : Void ==
            conform := get_property(page, 'conform)
            name := symbol(car(conform))
            kind := get_constructor_kind(name)
            domu := get_evalable_constructor_form(page, name)
            domu case Err_ind => error_page(domu)
            domname : SE := domu
            if not(null?(domname)) then
                set_property(page, 'domname, domname)
            pakname : SY :=
                kind = 'category => concat(string(name), "&")::SY
                name
            if not(null?(domname)) then
                conform := get_property(page, 'conform)
            c_lst : Cond_con_lst := uses(pakname, conform, domname)$BRI
            set_con_lst(page, c_lst)
            set_property(page, 'thing, convert("benefactor"))
            show_cons(page, 'names)

        parents_page(page : HyperdocPage) : Void ==
            conform := get_property(page, 'conform)
            name := symbol(car(conform))
            domu := get_evalable_constructor_form(page, name)
            domu case Err_ind => error_page(domu)
            domname : SE := domu
            if not(null?(domname)) then
                set_property(page, 'domname, domname)
            lst : Cond_con_lst := parents(convert(name))$BRI
            if not(null?(domname)) then
                lst := SUBLISLIS(cdr(domname), cdr(conform), lst)$Lisp
            page := new(copy_property_list(get_property_list(page)))
            set_con_lst(page, lst)
            set_property(page, 'thing, convert("parent"))
            choice : SY := (null?(domname) => 'names; 'parameters)
            show_cons(page, convert(choice))

        users_page(page : HyperdocPage) : Void ==
            conform := get_property(page, 'conform)
            name := symbol(car(conform))
            kind := get_constructor_kind(name)
            pakname : SY :=
                kind = 'category => concat(string(name), "&")::SY
                name
            d_lst : List(SY) := users(pakname)$BRI
            c_lst := [get_cons_form(d) for d in d_lst]
            set_con_lst(page, c_lst)
            set_property(page, 'thing, convert("user"))
            show_cons(page, 'names)

        show_cons_doc2(page : HyperdocPage, form : SE,
                       i : Integer, only_one : Boolean,
                       star? : Reference(Boolean)) : Void ==
            -- print(message("show_cons_doc2")$OutputForm)$OutputForm
            -- print(form::OutputForm)$OutputForm
            cfl := destruct(form)
            conname := symbol(first(cfl))
            args := rest(cfl)
            exp? := exp_con?(form)
            member?(conname, _$Primitives$Lisp)$List(SY) =>
                doc : String := ""
                sig : SE :=
                    conname = 'Enumeration =>
                        mk_fake_sig('Symbol)
                    mk_fake_sig('SetCategory)
                show_op_detail(page, "constructor", form, conname, sig,
                               true pretend SE, doc, i, only_one,
                               'dbSelectCon, false, false, star?)
                finish_constructor(page, conname)
            doc : String := constructor_documentation(conname)$BRI
            sig := constructor_signature(conname, args)$BRI
            show_op_detail(page, "constructor", form, conname, sig,
                           true pretend SE, doc, i, only_one,
                           'dbSelectCon, false, false, star?)
            finish_constructor(page, conname)

        show_cons_doc1(page : HyperdocPage, name : SY, i : Integer,
                       only_one : Boolean, star? : Reference(Boolean)
                      ) : Void ==
            if exposed_constructor?(name)$BRI then
                setref(star?, true)
            show_cons_doc2(page, constructor_form(name)$BRI, i,
                           only_one, star?)

        show_cons_doc(page : HyperdocPage, lst : List(SY),
                      star? : Reference(Boolean)) : Void ==
            lst := REMOVE_-DUPLICATES(lst)$Lisp
            not(empty?(lst)) and empty?(rest(lst)) =>
                show_cons_doc1(page, first(lst), 0, true, star?)
            i : Integer := 0
            c_lst := destruct(get_property(page, 'cAlist))
            for name in lst repeat
                while symbol(car(car(first(c_lst)))) ~= name repeat
                    i := i + 1
                    c_lst := rest(c_lst)
                show_cons_doc1(page, name, i, false, star?)

        begin_menu(page : HyperdocPage) : Void ==
            add_to_description(page, "\beginmenu ")

        end_menu(page : HyperdocPage) : Void ==
            add_to_description(page, "\endmenu ")

        get_constructor_kind(name : SY) : SY ==
            default_name?(name)$BRI => "default package"::SY
            constructor_kind(name)$BRI

        is_symbol?(se : SE, sy : SY) : Boolean ==
            symbol?(se) and symbol(se) = sy

        emit_constructor2(page : HyperdocPage, label : String, form : SE,
                         do_args : Boolean) : Void ==
            ls := con_to_strings(label, form, convert([]), do_args, true, [])
            add_list_to(page, reverse!(ls))

        emit_constructor1(page : HyperdocPage, form : SE, do_args : Boolean
                         ) : Void ==
            -- print(message("emit_constructor1")$OutputForm)$OutputForm
            -- print(form::OutputForm)$OutputForm
            ls := con_to_strings(form, convert([]), do_args, true, [])
            add_list_to(page, reverse!(ls))

        emit_constructor(page : HyperdocPage, form : SE) : Void ==
            emit_constructor1(page, form, true)

        emit_starred_constructor(page : HyperdocPage, form : SE,
                                 star? : Reference(Boolean)) : Void ==
            exp? : Boolean :=
                symbol?(form) => exposed_constructor?(symbol(form))$BRI
                list?(form) => exp_con?(form)
                true
            if not(exp?) then
                emit_star(page)
                setref(star?, true)
            emit_constructor(page, form)

        name_con_table(page: HyperdocPage, lst : Cond_con_lst,
                       do_args : Boolean,
                       star? : Reference(Boolean)) : Void ==
            had_unexposed? := false
            start_table(page)
            for rec in lst repeat
                form := rec.form
                exposed? := exp_con?(form)
                add_to_description(page, "{")
                if exposed? then
                    add_to_description(page, "\space{2}")
                else
                    emit_star(page)
                    had_unexposed? := true
                emit_constructor1(page, form, do_args)
                add_to_description(page, "}")
            end_table(page)
            if had_unexposed? then
                setref(star?, true)

        abbr_table(page: HyperdocPage, lst : Cond_con_lst, la : List(SY),
                   star? : Reference(Boolean)) : Void ==
            had_unexposed? := false
            start_table(page)
            for rec in lst for abb in la repeat
                form := rec.form
                exposed? := exp_con?(form)
                add_to_description(page, "{")
                if exposed? then
                    add_to_description(page, "\space{2}")
                else
                    emit_star(page)
                    had_unexposed? := true
                emit_constructor2(page, string(abb), form, false)
                add_to_description(page, "}")
            end_table(page)
            if had_unexposed? then
                setref(star?, true)

        show_cons_kinds(page : HyperdocPage, lst : Cond_con_lst,
                        star? : Reference(Boolean)) : Void ==
            cats := doms := packs := defs := []$List(Cond_rec)
            for l1 in lst repeat
                op := symbol(car(l1.form))
                kind : SY := get_constructor_kind(op)
                kind = 'category => cats := cons(l1, cats)
                kind = 'domain => doms := cons(l1, doms)
                kind = 'package => packs := cons(l1, packs)
                defs := cons(l1, defs)
            ll := [reverse!(cats), reverse!(doms), reverse!(packs),
                   reverse!(defs)]$List(List(Cond_rec))
            l_lab : List(String) := ["category", "domain", "package",
                                     "default package"]
            n_cases : Integer := +/[1 for l in ll | #l > 0]
            begin_menu(page)
            add_to_description(page, "\indent{1}")
            for l in ll for lab in l_lab repeat
                cnt := #l
                cnt = 0 => iterate
                add_to_description(page, "\item")
                if n_cases = 1 then
                    add_to_description(page, menu_button)
                else
                    lnk : List(SE) := [convert(lab), l pretend SE]
                    add_op_link0(page, 'bcLinks, menu_button,
                                 'dbShowConsKindsFilter, convert(lnk))
                add_to_description(page, "\tab{1}")
                add_to_description(page, "{\em ")
                add_to_description(page, convert(cnt)@String)
                add_to_description(page, " ")
                lab1 : String := (cnt > 1 => plural_form(lab); lab)
                add_to_description(page, lab1)
                add_to_description(page, ":}")
                name_con_table(page, l, false, star?)
            end_menu(page)
            add_to_description(page, "\indent{0}")

        split_unconditional(lst : Cond_con_lst
                           ) : Record(uncons : Cond_con_lst,
                                      conds : Cond_con_lst) ==
            uncos := conds := []$Cond_con_lst
            for el in lst repeat
                p := el.condition
                list?(p) and car(p) = convert('hasArgs) =>
                    -- error "hasArgs found"
                    uncos := cons(el, uncos)
                p = (true pretend SE) =>
                    uncos := cons(el, uncos)
                null?(p) =>
                    -- FIXME: this should be filtered out earlier
                    -- print(el.form::OutputForm)$OutputForm
                    iterate
                conds := cons(el, conds)
            [reverse!(uncos), reverse!(conds)]

        show_conditions1(page: HyperdocPage, lst : Cond_con_lst,
                         conname: SY, star? : Reference(Boolean)) : Void ==
            start_table(page)
            for r1 in lst repeat
                pred := r1.condition
                has_args : List(SE) := []
                if pred ~= (true pretend SE) then
                    has_arg1 : SE := extractHasArgs(pred)$Lisp
                    if not(null?(has_arg1)) then
                        pred := cdr(has_arg1)
                        has_args := destruct(car(has_arg1))
                add_to_description(page, "{")
                emit_starred_constructor(page, r1.form, star?)
                if not(empty?(has_args)) then
                    add_to_description(page, " {\em of} ")
                    n_con : SE := convert(cons(convert(conname), has_args))
                    emit_constructor(page, n_con)
                if pred ~= (true pretend SE) then
                    add_to_description(page, " if ")
                    emit_predicate(page, pred, r1.form)
                add_to_description(page, "}")
            end_table(page)

        show_conditions(page: HyperdocPage, lst : Cond_con_lst,
                        kind : SY, star? : Reference(Boolean)) : Void ==
            conform := get_property(page, 'conform)
            conname := symbol(car(conform))
            whichever := get_property(page,'whichever)
            -- print(message("before splitConTable")$OutputForm)$OutputForm
            (consNoPred, consPred) := split_unconditional(lst)
            kind_s := string(kind)
            singular : List(String) := [kind_s, " is"]
            plural : List(String)  := [plural_form(kind_s), " are"]
            cnt := #consNoPred
            cnt_str := get_count_str(cnt)
            -- print(message("before dbSayItems")$OutputForm)$OutputForm
            l_str : List(String) := cons(cnt_str,
                                         (cnt < 2 => singular; plural))
            add_list_to(page, l_str)
            add_to_description(page, " unconditional:")
            show_conditions1(page, consNoPred, conname, star?)
            add_to_description(page, "\horizontalline{}\newline{}")
            cnt := #consPred
            -- print(cnt::OutputForm)$OutputForm
            cnt_str := get_count_str(cnt)
            l_str := cons(cnt_str, (cnt < 2 => singular; plural))
            add_list_to(page, l_str)
            add_to_description(page, " conditional:")
            show_conditions1(page, consPred, conname, star?)

        con_page : SE -> Void

        constructor_page : (SY, List(SE), List(String)) -> Void

        star_remark(page : HyperdocPage) : Void ==
            add_to_description(page,
                "\newline{}-------------\newline{}{\em *} = unexposed")

        show_constructors2(page : HyperdocPage, lst : Cond_con_lst,
                           key : SY, exposedOnlyIfTrue : Boolean
                          ) : Void ==
            -- print(message("show_constructors2")$OutputForm)$OutputForm
            if exposedOnlyIfTrue then
                lst := [x for x in lst | exp_con?(x.form)]
            conlist := [e1.form for e1 in lst]
            -- print(conlist::OutputForm)$OutputForm
            not(empty?(conlist)) and empty?(rest(conlist)) =>
                c1 := first(conlist)
                dp := get_property(page, 'domname)
                null?(dp) =>
                    cl := destruct(c1)
                    constructor_page(symbol(first(cl)), cl, [])
                con_page(c1)
            name_lst : List(SY) := [
                symbol(first(destruct(e1))) for e1 in conlist]
            kinds := [get_constructor_kind(n) for n in name_lst]
            kinds := REMOVE_-DUPLICATES(kinds)$Lisp
            kind : SY :=
                #kinds = 1 => first(kinds)
                'constructor
            title := constructor_title(page, #name_lst, key, kind,
                                       exposedOnlyIfTrue)
            page := new(copy_property_list(get_property_list(page)))
            add_title(page, title)
            add_to_description(page, "\beginscroll ")
            set_con_lst(page, lst)
            star? := ref(false)$Reference(Boolean)
            -- print(message("calling branch fn")$OutputForm)$OutputForm
            if true then
                key = 'names => name_con_table(page, lst, false, star?)
                key = 'abbrs =>
                    la : List(SY) := [get_db_info(con, 'ABBREVIATION)
                                        for con in name_lst]
                    abbr_table(page, lst, la, star?)
                key = 'documentation => show_cons_doc(page, name_lst, star?)
                key = 'conditions => show_conditions(page, lst, kind, star?)
                key = 'parameters =>
                    name_con_table(page, lst, true, star?)
                key = 'kinds => show_cons_kinds(page, lst, star?)
            if deref(star?) then
                star_remark(page)
            add_to_description(page, "\endscroll ")
            -- print(message("calling constructor menu")$OutputForm)$OutputForm
            constructors_menu(page, kind, key)
            show(page)

        show_search_path(page : HyperdocPage) : Void ==
            conform := get_property(page, 'conform)
            name := symbol(car(conform))
            kind := get_constructor_kind(name)
            domu := get_evalable_constructor_form(page, name)
            domu case Err_ind => error_page(domu)
            domname : SE := domu
            title : List(String) :=
                null?(domname) =>
                    get_property(page, 'heading) pretend List(String)
                ["{\sf ", constructor_to_string(domname), "}"]
            if not(null?(domname)) then
                set_property(page, 'domname, domname)
                set_property(page, 'heading, title pretend SE)
            page := new(copy_property_list(get_property_list(page)))
            domain : None :=
                kind = 'category => NIL$Lisp
                EVAL(domname)$Lisp
            lst := search_path(conform, domname, domain)$BRI
            set_con_lst(page, lst)
            -- FIXME
            set_property(page, 'thing, convert("constructor"))
            show_cons(page, 'names)

        show_constructors(lst : List(SY)) : Void ==
            n_lst : Cond_con_lst := [get_cons_form(l1) for l1 in sort(lst)]
            page := new(empty())$HyperdocPage
            show_constructors2(page, n_lst, 'names, exposed_only?)

        con_page_choose(name : SE) : Void ==
            -- print(message("con_page_choose")$OutputForm)$OutputForm
            -- print(name::OutputForm)$OutputForm
            con_page(name)

        exposed_op? : Sig_doc -> Boolean

        show_op_documentation(page : HyperdocPage, s1 : Sig_doc, op : SY,
                              j : Integer, exactly_one : Boolean,
                              star? : Reference(Boolean)) : Void ==
            -- print(message("show_op_documentation")$OutputForm)$OutputForm
            doc := s1.documentation
            pred := s1.condition
            not_exp? := not(exposed_op?(s1))
            show_op_detail(page, "operation", s1.origin, op, s1.signature,
                           pred, doc, j, exactly_one, 'dbChooseDomainOp,
                           not_exp?, true, star?)
            if not_exp? then
                setref(star?, true)

        show_ops_documentation(page : HyperdocPage, opl : Op_lst,
                              exposedOnlyIfTrue : Boolean,
                              star? : Reference(Boolean)) : Void ==
            -- print(opl::OutputForm)$OutputForm
            conform := get_property(page, 'conform)
            domname := get_property(page, 'domname)
            if not(null?(domname)) then
                conform := domname
            exactly_one : Boolean := not(empty?(opl)) and empty?(rest(opl))
            exactly_one := exactly_one and #(first(opl).sdl) = 1
            for rec in opl for base in 0.. by 8192 repeat
                op := rec.name
                for s1 in rec.sdl for j in 0.. repeat
                    show_op_documentation(page, s1, op, base + j,
                                          exactly_one, star?)

        show_ops : (HyperdocPage, SE) -> Void

        choose_domain_op(page : HyperdocPage, k : Integer) : Void ==
            (opn, n) := divide(k, 8192)
            lst := get_op_lst(page)
            el := lst(opn + 1)
            op := el.name
            opd := (el.sdl)(n + 1)
            page := new(copy_property_list(get_property_list(page)))
            el2 := [op, [opd]]$Op_rec
            set_op_lst(page, [el2])
            show_ops(page, 'documentation)

        pack_pair(i : Integer, j : Integer) : SE ==
            lse : List(SE) := [convert(i), convert(j)]
            convert(lse)

        show_op_signatures : (HyperdocPage, Op_lst, Integer,
                              Reference(Boolean)) -> Void

        con_kind(c : SE) : String ==
            string(get_constructor_kind(symbol(car(c))))

        show_op_data(page : HyperdocPage, data : Grp_lst,
                     constructorIfTrue : Boolean, word : String,
                     fun : SY, star? : Reference(Boolean)) : Void ==
            set_ops_grd(page, data)
            single? := empty?(rest(data))
            begin_menu(page)
            bin_cnt : Integer := 1
            for el1 in data repeat
                tag := el1.grp_tag
                opl := el1.ops
                add_to_description(page, "\item")
                if single? then
                    add_to_description(page, menu_button)
                else
                    add_op_link0(page, 'bcLinks, menu_button, 'dbShowOps,
                                 pack_pair(bin_cnt, 0))
                add_to_description(page, "{\em ")
                phrase1 : String :=
                    symbol?(tag) =>
                        st := symbol(tag)
                        st = 'nowhere => "implemented nowhere"
                        st = 'constant => "constant"
                        st = 'unexported => "unexported"
                        st = '% => "by the domain"
                        constructorIfTrue =>
                            add_to_description(page, word)
                            " an unknown constructor"
                        "unconditional"
                    list?(tag) =>
                        constructorIfTrue =>
                            add_to_description(page, word)
                            ""
                        ""
                    error "show_op_data: unexpected tag"
                add_to_description(page, phrase1)
                add_to_description(page, "}")
                if list?(tag) then
                    if constructorIfTrue then
                        add_list_to(page,
                                    [" {\em ", con_kind(tag), "}"])
                    add_to_description(page, " ")
                    fun = 'bcStarConform =>
                         emit_starred_constructor(page, tag, star?)
                    fun = 'bcPred =>
                        emit_predicate(page, tag, convert([]))
                    error "show_op_data: unexpected function symbol"
                add_to_description(page, ":\newline ")
                show_op_signatures(page, opl, bin_cnt, star?)
                bin_cnt := bin_cnt + 1
            end_menu(page)

        show_op_origins(page : HyperdocPage, lst : Op_lst,
                        star? : Reference(Boolean)) : Void ==
            data := group_by_origin(lst)$BRI
            show_op_data(page, data, true, "from", 'bcStarConform, star?)

        show_op_implementations(page : HyperdocPage, lst : Op_lst,
                        star? : Reference(Boolean)) : Void ==
            -- print(message("show_op_implementations")$OutputForm)$OutputForm
            -- print(lst::OutputForm)$OutputForm
            domname := get_property(page, 'domname)
            null?(domname) =>
                error "show_op_implementations: no domname"
            -- print(domname::OutputForm)$OutputForm
            args := rest(destruct(constructor_form(symbol(car(domname)))$BRI))
            data := group_by_implementation(args, domname, lst)$BRI
            -- print(data::OutputForm)$OutputForm
            show_op_data(page, data, true, "by", 'bcStarConform, star?)

        show_op_conditions(page : HyperdocPage, lst : Op_lst,
                           star? : Reference(Boolean)) : Void ==
            -- print(message("show_op_conditions")$OutputForm)$OutputForm
            data := group_by_condition(lst)$BRI
            -- print(data::OutputForm)$OutputForm
            show_op_data(page, data, false, "", 'bcPred, star?)

        ops_title_suffix(branch : SY) : String ==
            branch = 'parameters => " viewed with parameters"
            branch = 'origins    => " organized by origins"
            branch = 'conditions => " organized by conditions"
            ""

        from_part(page : HyperdocPage) : List(String) ==
            res := get_property(page, 'fromHeading) pretend List(String)
            res

        drop_unexposed_ops : Op_lst -> Op_lst

        count_ops : Op_lst -> Integer

        emit_star(page : HyperdocPage) : Void ==
            add_to_description(page, "{\em *} ")

        show_op_names(page : HyperdocPage, opl : Op_lst,
                      star? : Reference(Boolean)) : Void ==
            -- print(message("show_op_names")$OutputForm)$OutputForm
            had_star? := false
            start_table(page)
            for i in 0.. for rec in opl repeat
                exposed? := false
                for sd in rec.sdl repeat
                    exposed? := exposed? or exposed_op?(sd)
                add_to_description(page, "{")
                if exposed? then
                        add_to_description(page, "\space{2}")
                else
                    had_star? := true
                    emit_star(page)
                lnk1 : SE := convert(i)
                ns := escape_if_needed(string(rec.name))
                add_op_link0(page, 'bcLinks, ns, 'dbShowOps, lnk1)
                add_to_description(page, "}")
            end_table(page)
            if had_star? then
                setref(star?, true)

        show_op_parameters(page : HyperdocPage, opl : Op_lst,
                      star? : Reference(Boolean)) : Void ==
            had_star? := false
            start_table(page)
            i : Integer := 0
            for rec in opl repeat
                op := rec.name
                for sd in rec.sdl repeat
                    i := i + 1
                    exposed? := exposed_op?(sd)
                    add_to_description(page, "{")
                    if exposed? then
                        add_to_description(page, "\space{2}")
                    else
                        had_star? := true
                        emit_star(page)
                    args := operation_arguments(op, sd.signature,
                                                sd.documentation)
                    display_op_sig(page, convert(op), args pretend List(SE),
                                   #args + 1, sd.condition,
                                     convert(i), false)
                    add_to_description(page, "}")
            end_table(page)
            if had_star? then
                setref(star?, true)

        show_op_signatures(page : HyperdocPage, opl : Op_lst, j : Integer,
                           star? : Reference(Boolean)) : Void ==
            had_star? := false
            start_table(page)
            i : Integer := 1
            for rec in opl repeat
                for sd in rec.sdl repeat
                    exposed? := exposed_op?(sd)
                    add_to_description(page, "{")
                    if exposed? then
                        add_to_description(page, "\space{2}")
                    else
                        had_star? := true
                        emit_star(page)
                    lnk1 : SE :=
                        j = 0 => convert(i)
                        pack_pair(j, i)
                    i := i + 1
                    ns := escape_if_needed(string(rec.name))
                    add_op_link0(page, 'bcLinks, ns,
                                 'dbShowOps, lnk1)
                    add_to_description(page, ": ")
                    mt : List(SE) := cons(convert('Mapping),
                                          destruct(sd.signature))
                    -- print(mt::OutputForm)$OutputForm
                    emit_constructor(page, convert(mt))
                    add_to_description(page, "}")
            end_table(page)
            if had_star? then
                setref(star?, true)

        show_op_lines0(page : HyperdocPage, opl : Op_lst,
                       key : SY, exposedOnlyIfTrue : Boolean) : Void ==
            -- print(message("show_op_lines0")$OutputForm)$OutputForm
            -- print(opl::OutputForm)$OutputForm
            -- print(key::OutputForm)$OutputForm
            if exposedOnlyIfTrue then
                opl := drop_unexposed_ops(opl)
                -- print(message("exposed only")$OutputForm)$OutputForm
                -- print(opl::OutputForm)$OutputForm
            cnt : Integer := count_ops(opl)
            branch : SY :=
                key = 'names and empty?(rest(opl)) =>
                    cnt <= max_description_count => 'documentation
                    key
                key
            cnt2 := #opl
            -- print(message("cnt2 = ")$OutputForm)$OutputForm
            -- print(cnt2::OutputForm)$OutputForm
            namedPart : List(String) :=
                not(empty?(opl)) and empty?(rest(opl)) =>
                    op1 := first(opl).name
                    [" {\em ", escape_if_needed(string(op1)), "}"]
                []
            cnt_str := get_count_str(cnt)
            prefix :=
                exposedOnlyIfTrue => [cnt_str, " exposed "]
                [cnt_str]
            title : List(String) :=
                cnt = 0 => concat(prefix, "operations")
                cnt2 = 1 or cnt2 = cnt =>
                    cnt = 1 =>
                        exposedOnlyIfTrue => concat(
                           ["Exposed ", "operation"], namedPart)
                        concat(["Operation", " "], namedPart)
                    concat(prefix, cons("operations", namedPart))
                concat([convert(cnt2)@String, " names for ", cnt_str,
                        "operations"], namedPart)
            page := new(copy_property_list(get_property_list(page))
                       )$HyperdocPage
            title := concat(title, from_part(page))
            title := concat(title, ops_title_suffix(branch))
            -- print(title::OutputForm)$OutputForm
            add_title(page, title)
            set_property(page, 'branch, convert(branch))
            add_to_description(page, "\beginscroll ")
            -- print(message("calling branch fn")$OutputForm)$OutputForm
            star? := ref(false)$Reference(Boolean)
            if true then
                branch = 'names =>
                    show_op_names(page, opl, star?)
                branch = 'documentation =>
                    show_ops_documentation(page, opl, exposedOnlyIfTrue, star?)
                branch = 'signatures =>
                    show_op_signatures(page, opl, 0, star?)
                branch = 'parameters =>
                    show_op_parameters(page, opl, star?)
                branch = 'origins =>
                    show_op_origins(page, opl, star?)
                branch = 'implementation =>
                    show_op_implementations(page, opl, star?)
                branch = 'conditions =>
                    show_op_conditions(page, opl, star?)
            -- print(message("branch fn done")$OutputForm)$OutputForm
            if deref(star?) then
                star_remark(page)
            add_to_description(page, "\endscroll ")
            operations_menu(page, branch, exposedOnlyIfTrue)
            show(page)

        show_op_lines3(page : HyperdocPage, opl : Op_lst,
                       key : SY) : Void ==
            -- print(message("show_op_lines3")$OutputForm)$OutputForm
            -- print(lst::OutputForm)$OutputForm
            show_op_lines0(page, opl, key, exposed_only?)

        show_op_lines(opl : Op_lst) : Void ==
            -- print(message("show_op_lines")$OutputForm)$OutputForm
            page := new(empty())$HyperdocPage
            set_op_lst(page, opl)
            show_op_lines3(page, opl, 'names)

        search_query(tag : SY, kind : String) : Void ==
            items : List(SE) := [convert(tag), convert(kind)]
            page := new(empty())$HyperdocPage
            set_property(page, 'items, convert(items))
            add_title(page, ["Query Page"])
            add_to_description(page, "\beginscroll ")
            emit_query(page, ["{\em Do you want a list of {\em all} ",
                plural_form(kind), "?\vspace{1}}"], 'grepSearchJump)
            add_to_description(page, "\endscroll")
            show(page)

        do_operation_search(pat : String) : Void ==
            opl_u := search_operations(pat)$BRI
            opl_u case Err_ind => error_page(opl_u)
            opl := opl_u@Op_lst
            cnt := #opl
            cnt = 0 =>
                empty_result("operation", pat, "")
            show_op_lines(opl)

        operation_search(pat : String) : Void ==
            -- print(message("operation_search")$OutputForm)$OutputForm
            pat = "*" => search_query('o, "operation")
            do_operation_search(pat)

        add_link1(page : HyperdocPage, label : String, fun : SY) : Void ==
            add_op_link0(page, 'bcLinks, label, 'cons_opts, convert(fun))

        add_link(page : HyperdocPage, label : String, fun : SY) : Void ==
            add_to_description(page, "}{")
            add_link1(page, label, fun)

        constructor_context_menu(page : HyperdocPage, kind : String,
               is_asharp? : Boolean) : Void ==
            start_table(page)
            add_to_description(page, "{")
            add_link1(page, "Ancestors", 'ancestors)
            if kind = "category" then
                add_link(page, "Children", 'children)
            if not(is_asharp?) then
                add_link(page, "Dependents", 'dependents)
            if kind = "category" then
                add_link(page, "Descendents", 'descendents)
                if not(is_asharp?) then
                    add_link(page, "Domains", 'domains)
                else
                    add_to_description(page, "}{{\em Domains}")
            -- FIXME
            add_to_description(page, "}{{\em Examples}")
            add_link(page, "Exports", 'exports)
            add_link(page, "Operations", 'operations)
            add_link(page, "Parents", 'parents)
            if kind ~= "category" then
                if not(is_asharp?) then
                    add_link(page, "Search Path", 'search_path)
                else
                    add_to_description(page, "}{{\em Search Path}")
                add_link(page, "Users", 'users)
                add_link(page, "Uses", 'uses)
            add_to_description(page, "}")
            end_table(page)

        add_parameter_fields(page : HyperdocPage, conform : List(SE),
                                a_strs : List(String)) : Void ==
            parlist : List(String) :=
                [string(symbol(par)) for par in rest(conform)]
            need_wide? := "max"/[#s for s in parlist] > 10
            w : Integer := (need_wide? => 55; 23)
            add_to_description(page, "Optional argument ")
            val_str : String :=
                not(empty?(rest(parlist))) => "values:"
                "value:"
            add_to_description(page, val_str)
            even := false
            pvars : List(SY) := _$PatternVariableList$Lisp
            for parname in pvars for par in rest(conform)
                                 for spar in parlist repeat
                par := fix_T(par)
                add_to_description(page,
                    (even or need_wide? => "\newline"; "\tab{29}"))
                even := not(even)
                a_str : String := ""
                if not(empty?(a_strs)) then
                    a_str := first(a_strs)
                    a_strs := rest(a_strs)
                l1 : List(SE) :=
                    [convert('text), convert("{\em "), par, convert("} = ")]
                l2 : List(SE) :=
                    [convert(w - #spar), convert(a_str),
                      convert(parname), convert('EM)]
                add_to(page, [convert(l1),
                              convert([convert('bcStrings), convert(l2)])])

        capitalize(s : String) : String ==
            s := copy(s)
            s(1) := upperCase(s(1))$Character
            s

        constructor_page(name : SY, form : List(SE), args : List(String)
                        ) : Void ==
            kind : SY := get_constructor_kind(name)
            kind_s := string(kind)
            conform : SE := constructor_form(name)$BRI
            nargs := #conform - 1
            -- if empty?(args) and nargs > 0 then
            --    args := [string(symbol(ai)) for ai in rest(destruct(conform))]
            constrings : List(String) :=
                #form > 1 => con_to_strings(name, form)
                [string(name)]
            heading := concat(constrings, ["}"])
            heading := cons("{", heading)
            exp? : Boolean := exposed_constructor?(name)$BRI
            heading1 : List(String) :=
                exp? => [capitalize(kind_s), " "]
                ["Unexposed ", kind_s, " "]
            title := concat(heading1, heading)
            page := new(empty())$HyperdocPage
            add_title(page, title)
            add_to_description(page, "\beginscroll ")
            set_property(page, 'heading, heading pretend SE)
            set_property(page, 'kind, convert(kind_s))
            set_property(page, 'conform, conform)
            -- set_property(page, 'signature, convert(signature))
            -- print(message("calling show_cons_doc2")$OutputForm)$OutputForm
            star? := ref(exp?)$Reference(Boolean)
            show_cons_doc2(page, conform, 0, true, star?)
            if nargs > 0 then
                add_parameter_fields(page, destruct(conform), args)
            if not(deref(star?)) then
                star_remark(page)
            add_to_description(page, "\endscroll ")
            constructor_context_menu(page, kind_s, false)
            show(page)

        show_split_constructors : (Split_rec, String, String) -> Void

        show_constructor_res(lst_u : Con_res, desc : String, pat : String
                            ) : Void ==
            lst_u case Err_ind => error_page(lst_u)
            show_split_constructors(lst_u, desc, pat)

        do_constructor_search(pat : String, tag : SY, desc : String
                          ) : Void ==
            -- print(message("do_constructor_search")$OutputForm)$OutputForm
            lst_u := search_constructors(pat, tag)$BRI
            show_constructor_res(lst_u, desc, pat)

        con_with_params?(pat : String) : SE ==
            pat = "Mapping" => convert([])
            pt := parse(pat)$InputForm
            null?(pt) => convert(pt)
            quiet_valid_type?(pt)$Lisp

        constructor_search(pat : String, tag : SY, desc : String
                          ) : Void ==
            parse : SE := con_with_params?(pat)
            not(null?(parse)) =>
                -- print(message("calling con_page")$OutputForm)$OutputForm
                con_page(parse)
            su : Union(SY, "failed") := find_symbol(pat)$Lisp
            if su case SY then
                s := su@SY
                cn : SE := get_db_info(s, 'CONSTRUCTOR)
                if symbol?(cn) then
                    pat := string(symbol(cn))
            lu := is_builtin?(pat)
            lu case String => downlink(lu)
            pat = "*" => search_query(tag, desc)
            do_constructor_search(pat, tag, desc)

        exposed_op?(sd : Sig_doc) : Boolean ==
            orig_name := car(sd.origin)
            exposed_constructor?(symbol(orig_name))$BRI

        drop_unexposed_sigs(sdl : List(Sig_doc)) : List(Sig_doc) ==
            [sd for sd in sdl | exposed_op?(sd)]

        drop_unexposed_ops(opl : Op_lst) : Op_lst ==
            res : Op_lst := []
            for rec in opl repeat
                sdl1 := drop_unexposed_sigs(rec.sdl)
                empty?(sdl1) => iterate
                res := cons([rec.name, sdl1], res)
            reverse!(res)

        drop_unexposed_constructors(lst : List(SY)) : List(SY) ==
            [name for name in lst | exposed_constructor?(name)$BRI]

        drop_unexposed_lines(lst : Save_rec) : Save_rec ==
            -- print(message("drop_unexposed_lines")$OutputForm)$OutputForm
            -- print(lst::OutputForm)$OutputForm
            not(exposed_only?) => lst
            ci := lst.save.con_info
            cats := drop_unexposed_constructors(ci.categories)
            doms := drop_unexposed_constructors(ci.domains)
            packs := drop_unexposed_constructors(ci.packages)
            opl := drop_unexposed_ops(lst.save.op_info)
            [[[cats, doms, packs], opl], lst.save]

        count_ops(opl : Op_lst) : Integer ==
            res : Integer := 0
            for rec in opl repeat
                res := res + #rec.sdl
            res

        count_lsts(le : Gen_rec) : Integer ==
            -- print(message("count_lsts")$OutputForm)$OutputForm
            -- print(le::OutputForm)$OutputForm
            cr := le.con_info
            #cr.categories + #cr.domains + #cr.packages +
                count_ops(le.op_info)

        show_split_constructors(lst : Split_rec, kind : String, pat : String
                               ) : Void ==
            n_lst := concat(lst.categories,
                            concat(lst.domains, lst.packages))
            empty?(n_lst) => empty_result(kind, pat, "")
            show_constructors(n_lst)

        show_single_list(rec : Gen_rec) : Void ==
            not(empty?(rec.op_info)) =>
                show_op_lines(rec.op_info)
            ci := rec.con_info
            not(empty?(ci.categories)) =>
                show_constructors(ci.categories)
            not(empty?(ci.domains)) =>
                show_constructors(ci.domains)
            not(empty?(ci.packages)) =>
                show_constructors(ci.packages)
            error "show_single_list: all lists are empty"

        say_item_count(page : HyperdocPage, pre : String, cnt : Integer,
                       singular : String, plural : String,
                       tail : List(String)) : Void ==
            -- print(message("say_item_count")$OutputForm)$OutputForm
            add_to_description(page, "\newline ")
            if pre ~= "" then
                add_to_description(page, pre)
            cnt_str := get_count_str(cnt)
            add_to_description(page, cnt_str)
            add_to_description(page, (cnt < 2 => singular; plural))
            for el in tail repeat
                add_to_description(page, el)
            if cnt > 0 then
                add_to_description(page, ":")

        emit_gen_ops(page : HyperdocPage, c_opl : Op_lst, s_opl : Op_lst,
                     j : Integer, fn : SY, star? : Reference(Boolean)
                    ) : Void ==
            cnt := count_ops(c_opl)
            u_cnt := #c_opl
            cnt = 0 => void()
            -- print(message("emit_gen_ops")$OutputForm)$OutputForm
            -- print(cnt::OutputForm)$OutputForm
            add_to_description(page, "\newline ")
            add_to_description(page, "\tab{2}")
            kind : String := "operation"
            lnk1 : List(SE) := [c_opl pretend SE, convert(kind)]
            add_op_link0(page, 'bcLinks, menu_button, 'genSearchSayJump,
                          convert(lnk1))
            add_to_description(page, "{\em ")
            cnt_str := get_count_str(cnt)
            add_to_description(page, cnt_str)
            add_to_description(page, (cnt < 2 => kind; plural_form(kind)))
            add_to_description(page, "} ")
            u_cnt >= max_browse_count => void()
            if u_cnt ~= 1 then
                add_to_description(page, "\indent{4}")
                add_to_description(page, "\newline ")
                start_table(page)
            had_star? := false
            i : Integer := 0
            for rec in c_opl repeat
                id := rec.name
                exposed? := false
                for sd in rec.sdl repeat
                    exposed? := exposed? or exposed_op?(sd)
                add_to_description(page, "{")
                if exposed? then
                        add_to_description(page, "\space{1}")
                else
                    had_star? := true
                    emit_star(page)
                lnk1 : SE := convert(j + 8*i)
                add_op_link0(page, 'bcLinks, string(id), fn, lnk1)
                -- i := i + #rec.sdl
                i := i + 1
                add_to_description(page, "}")
            if u_cnt ~= 1 then
                end_table(page)
                add_to_description(page, "\indent{0}")
            if had_star? then
                setref(star?, true)

        emit_gen_item(page: HyperdocPage, c_lst : List(SY),
                      s_lst : List(SY), kind : String, j : Integer,
                      fn : SY, star? : Reference(Boolean)) : Void ==
            cnt : Integer := #c_lst
            cnt = 0 => void()
            -- unique_cnt : Integer := #u
            -- print(message("emit_gen_item")$OutputForm)$OutputForm
            -- print(cnt::OutputForm)$OutputForm
            add_to_description(page, "\newline ")
            add_to_description(page, "\tab{2}")
            lnk1 : List(SE) := [s_lst pretend SE,
                                         convert(kind)]
            add_op_link0(page, 'bcLinks, menu_button, 'genSearchSayJump,
                          convert(lnk1))
            add_to_description(page, "{\em ")
            cnt_str := get_count_str(cnt)
            add_to_description(page, cnt_str)
            add_to_description(page, (cnt < 2 => kind; plural_form(kind)))
            add_to_description(page, "} ")
            cnt >= max_browse_count => void()
            if cnt ~= 1 then
                add_to_description(page, "\indent{4}")
                add_to_description(page, "\newline ")
                start_table(page)
            i : Integer := 1
            had_star? := false
            for id in c_lst repeat
                exposed? := exposed_constructor?(id)$BRI
                add_to_description(page, "{")
                if exposed? then
                    add_to_description(page, "\space{1}")
                else
                    had_star? := true
                    emit_star(page)
                lnk1 : SE := convert(j + 8*i)
                add_op_link0(page, 'bcLinks, string(id), fn, lnk1)
                i := i + 1
                add_to_description(page, "}")
            if cnt ~= 1 then
                end_table(page)
                add_to_description(page, "\indent{0}")
            if had_star? then
                setref(star?, true)

        add_exposure_button(page : HyperdocPage) : Void ==
            cond : Boolean := not(exposed_only?)
            lnk1 : List(SE) := [
                convert(cond => "Exposed Only"; "Unexposed Also"),
                    convert(""), convert('repeatSearch),
                        cond pretend SE]
            lnk : List(SE) := [convert('bcLinks), convert(lnk1)]
            add_to(page, [convert(lnk)])

        emit_gen_lst(page : HyperdocPage, rec : Save_rec,
                     fn : SY, star? : Reference(Boolean)) : Void ==
            -- print(message("emit_gen_lst")$OutputForm)$OutputForm
            ccur := rec.cur.con_info
            csave := rec.save.con_info
            emit_gen_ops(page, rec.cur.op_info, rec.save.op_info,
                         0, fn, star?)
            emit_gen_item(page, ccur.categories, csave.categories,
                              "category", 1, fn, star?)
            emit_gen_item(page, ccur.domains, csave.domains,
                              "domain", 2, fn, star?)
            emit_gen_item(page, ccur.packages, csave.packages,
                              "package", 3, fn, star?)

        doc_search1(pat : String, doc_lst : Save_rec) : Void ==
            doc_lst := drop_unexposed_lines(doc_lst)
            cnt : Integer := count_lsts(doc_lst.cur)
            cnt = 0 =>
                empty_result("entry", pat, "")
            cnt = 1 =>
                -- lst1 := first(get_not_empties(doc_lst))
                -- FIXME
                show_single_list(doc_lst.cur)
            page := new(empty())$HyperdocPage
            set_reg_list(page, "failed")
            set_doc_list(page, doc_lst)
            set_property(page, 'filter, convert(pat))
            title : List(String) := [get_count_str(cnt),
                (cnt < 2 => "entry matches"; "entries match"), " ",
                    "{\em ", escape_if_needed(pat), "}"]
            add_title(page, title)
            add_to_description(page, "\beginscroll ")
            say_item_count(page, "\newline Documentation Summary: ", cnt,
                           "mention", "mentions", [" of {\em ", pat, "}"])
            star? := ref(false)$Reference(Boolean)
            emit_gen_lst(page, doc_lst, 'showDoc, star?)
            if deref(star?) then
                star_remark(page)
            add_to_description(page, "\endscroll")
            add_exposure_button(page)
            show(page)

        gen_search1(pat : String, reg_lst : Save_rec,
                    doc_lst : Save_rec) : Void ==
            -- print(message("gen_search1")$OutputForm)$OutputForm
            reg_lst := drop_unexposed_lines(reg_lst)
            doc_lst := drop_unexposed_lines(doc_lst)
            reg_cnt : Integer := count_lsts(reg_lst.cur)
            doc_cnt : Integer := count_lsts(doc_lst.cur)
            cnt := reg_cnt + doc_cnt
            -- print(message("gen_search1, [reg_cnt, doc_cnt] = "
            --     )$OutputForm)$OutputForm
            -- print(([reg_cnt, doc_cnt]$List(Integer))::OutputForm)$OutputForm
            cnt = 0 =>
                empty_result("entry", pat, "")
            cnt = 1 =>
                -- print(message("cnt = 1 =>")$OutputForm)$OutputForm
                lst := (reg_cnt = 1 => reg_lst.cur; doc_lst.cur)
                show_single_list(lst)
            page := new(empty())$HyperdocPage
            set_reg_list(page, reg_lst)
            set_doc_list(page, doc_lst)
            set_property(page, 'filter, convert(pat))
            pre1 : String :=
                exposed_only? => "exposed entries match"
                "entries match"
            pre2 : String := concat([convert(cnt)@String, " ", pre1])
            title := [pre2, " {\em ", escape_if_needed(pat), "}"]
            add_title(page, title)
            add_to_description(page, "\beginscroll ")
            if doc_cnt > 0 then
                say_item_count(page, "{\bf Construct Summary:} ", reg_cnt,
                               "name matches", "names match", [])
            star? := ref(false)$Reference(Boolean)
            emit_gen_lst(page, reg_lst, 'showConstruct, star?)
            if doc_cnt > 0 then
                say_item_count(page, "\newline{\bf Documentation Summary:} ",
                               doc_cnt, "mention", "mentions",
                               [" of {\em ", pat, "}"])
                emit_gen_lst(page, doc_lst, 'showDoc, star?)
            if deref(star?) then
                star_remark(page)
            add_to_description(page, "\endscroll")
            add_exposure_button(page)
            show(page)

        doc_search0(pat : String) : Void ==
            pat = "*" => star_error()
            doc_u := search_documentation(pat)$BRI
            doc_u case Err_ind => error_page(doc_u)
            doc_search1(pat, [doc_u, doc_u])

        gen_search0(pat : String, includeDoc? : Boolean) : Void ==
            -- print(message("gen_search0")$OutputForm)$OutputForm
            pat = "*" => star_error()
            reg_u := search_general(pat)$BRI
            reg_u case Err_ind => error_page(reg_u)
            doc_lst : Gen_rec := [[[], [], []], []]
            if includeDoc? then
                doc_u := search_documentation(pat)
                doc_u case Err_ind => error_page(doc_u)
                doc_lst := doc_u
            gen_search1(pat, [reg_u, reg_u], [doc_lst, doc_lst])

        repeat_search(page : HyperdocPage, exp? : Boolean) : Void ==
            exposed_only? := exp?
            pat := string(get_property(page, 'filter))
            reg_lst_u := get_reg_list(page)
            doc_lst := get_doc_list(page)
            reg_lst_u case "failed" => doc_search1(pat, doc_lst)
            gen_search1(pat, reg_lst_u, doc_lst)

        select_opr(page : HyperdocPage, opl : Op_lst, k : Integer
                  ) : Op_rec ==
            -- print(message("select_opr")$OutputForm)$OutputForm
            -- print(opl::OutputForm)$OutputForm
            -- print(#opl::OutputForm)$OutputForm
            -- print(k::OutputForm)$OutputForm
            branch :=
                bs := get_property(page, 'branch)
                null?(bs) => 'names
                symbol(bs)
            -- print(branch::OutputForm)$OutputForm
            branch = 'names => opl(k + 1)
            j := j0 := 1$Integer
            repeat
                opr := first(opl)
                j0 := j
                j := j + #opr.sdl
                j > k => break
                opl := rest(opl)
            -- print((k - j0)::OutputForm)$OutputForm
            -- print(opr::OutputForm)$OutputForm
            sd := (opr.sdl)(k - j0 + 1)
            [opr.name, [sd]]

        show_selected_ops(page : HyperdocPage, opl : Op_lst) : Void ==
            page := new(copy_property_list(get_property_list(page))
                       )$HyperdocPage
            set_op_lst(page, opl)
            branch : SY :=
                #opl ~= 1 => 'names
                ope := first(opl)
                #ope.sdl <= max_description_count => 'documentation
                'names
            show_op_lines0(page, opl, branch, exposed_only?)

        show_ops_int(page : HyperdocPage, opl : Op_lst, k : Integer
                    ) : Void ==
            opr := select_opr(page, opl, k)
            opl := [opr]
            show_selected_ops(page, opl)

        show_ops_list(page : HyperdocPage, pair : List(SE)) : Void ==
            -- print(message("show_ops_list")$OutputForm)$OutputForm
            -- print(pair::OutputForm)$OutputForm
            i := integer(first(pair))
            j := integer(pair(2))
            grd := get_ops_grd(page)
            opl := grd(i).ops
            j = 0 =>
                show_selected_ops(page, opl)
            ope := select_opr(page, opl, j)
            opl := [ope]
            show_selected_ops(page, opl)

        get_input_string : (HyperdocPage, SY) -> String

        show_ops_filter(page : HyperdocPage, op_lst : Op_lst
                       ) : Void ==
            pat : String := get_input_string(page, 'filter)
            pat2 := convert_pattern(pat)$BRI
            pat2 case Err_ind => error_page(pat2)
            op_lst := filter_ops(pat2, op_lst)$BRI
            empty?(op_lst) =>
                empty_result("operation", pat, "")
            page := new(copy_property_list(get_property_list(page))
                       )$HyperdocPage
            set_op_lst(page, op_lst)
            show_ops(page, get_property(page, 'exclusion))

        show_ops(page : HyperdocPage, key : SE) : Void ==
            op_lst := get_op_lst(page)
            list?(key) =>
                show_ops_list(page, destruct(key))
            integer?(key) =>
                show_ops_int(page, op_lst, integer(key))
            not(symbol?(key)) =>
                error "show_ops: unexpected form of key"
            branch := symbol(key)
            branch = 'filter =>
                show_ops_filter(page, op_lst)
            set_property(page, 'key, key)
            exposedOnlyIfTrue : Boolean := exposed_only?
            if branch = 'exposureOn or branch = 'exposureOff then
                exposedOnlyIfTrue := branch = 'exposureOn
                key := get_property(page, 'exclusion)
                exposed_only? := exposedOnlyIfTrue
            show_op_lines0(page, op_lst, symbol(key), exposedOnlyIfTrue)

        con_filter_match(pat : LMA, c : SE, abbrev? : Boolean) : Boolean ==
            conname := symbol(car(car(c)))
            subject : SY :=
                abbrev? => constructor?(conname)$Lisp
                conname
            do_match(pat, string(subject))$BRI

        show_cons_filter(page : HyperdocPage) : Void ==
            pat : String := get_input_string(page, 'filter)
            pat2 := convert_pattern(pat)$BRI
            pat2 case Err_ind => error_page(pat2)
            con_lst := destruct(get_property(page, 'cAlist))
            e_prop := get_property(page, 'exclusion)
            abbrev? : Boolean := is_symbol?(e_prop, 'abbrs)
            con_lst := [c for c in con_lst |
                        con_filter_match(pat2, c, abbrev?)]
            empty?(con_lst) => empty_result("constructor", pat, "")
            page := new(copy_property_list(get_property_list(page))
                       )$HyperdocPage
            set_property(page, 'cAlist, convert(con_lst))
            show_cons(page, get_property(page, 'exclusion))

        show_cons(page : HyperdocPage, key : SE) : Void ==
            branch := symbol(key)
            branch = 'filter =>
                show_cons_filter(page)
            exposedOnlyIfTrue : Boolean := exposed_only?
            if branch = 'exposureOn or branch = 'exposureOff then
                exposedOnlyIfTrue := branch = 'exposureOn
                key := get_property(page, 'exclusion)
                exposed_only? := exposedOnlyIfTrue
            show_constructors2(page, get_con_lst(page), symbol(key),
                             exposed_only?)

        do_filter(page : HyperdocPage, data : SE) : Void ==
            page := new(copy_property_list(get_property_list(page))
                       )$HyperdocPage
            add_title(page, ["Filter String"])
            add_to_description(page, "\beginscroll ")
            add_to_description(page,
              "\centerline{Enter filter string (use {\em *} for wild card):}")
            add_to_description(page, "\centerline{")
            l1 : List(SE) := [convert(50), convert(""),
                                       convert('filter), convert('EM)]
            l1 := [convert('bcStrings), convert(l1)]
            add_to(page, [convert(l1)])
            add_to_description(page, "}\vspace{1}\centerline{")
            l1 := concat([convert("\fbox{Filter}"), convert("")],
                          destruct(data))
            l1 := [convert('bcLispLinks), convert(l1)]
            add_to(page, [convert(l1)])
            add_to_description(page, "}")
            add_to_description(page, "\endscroll")
            show(page)

        show_it(page : HyperdocPage, count : SE, ls : Save_rec
               ) : Void ==
            cnt := integer(count)
            (q, r) := divide(cnt, 8)
            r = 0 => show_ops_int(page, ls.cur.op_info, q)
            kind : SY
            cur := ls.cur.con_info
            lst : List(SY) :=
                r = 1 =>
                    kind := 'category
                    cur.categories
                r = 2 =>
                    kind := 'domain
                    cur.domains
                r = 3 =>
                    kind := 'package
                    cur.packages
                error "show_it: wrong r"
            for j in 1.. while j < q repeat
                lst := rest(lst)
            name := first(lst)
            show_constructors([name])

        gen_search_jump(page : HyperdocPage, u : SE) : Void ==
            -- print(message("gen_search_jump")$OutputForm)$OutputForm
            (ls, kinde) := destruct(u)
            kind := string(kinde)
            pat : String := string(get_property(page, 'filter))
            -- print(kind::OutputForm)$OutputForm
            kind = "operation" =>
                show_op_lines(ls pretend Op_lst)
            show_constructors(ls pretend List(SY))

        do_search_jump(page : HyperdocPage) : Void ==
            (te, ke) := destruct(get_property(page, 'items))
            tag := symbol(te)
            kind := string(ke)
            pat : String := "*"
            kind = "operation" =>
                do_operation_search(pat)
            do_constructor_search(pat, tag, kind)

        sfT ==> (String -> Boolean)
        ifT ==> (Integer -> Boolean)

        do_detailed_operation_search(page : HyperdocPage, nam_f : sfT,
                                     ari_f : ifT, sig_f : sfT) : Op_lst ==
            f1 : (String, Sig_doc) -> Boolean := (n, sd) +->
                not(nam_f(n)) => false
                sig := sd.signature
                not(ari_f(#destruct(sig) - 1)) => false
                sl := cons(convert('Mapping), destruct(sig))
                sig_f(constructor_to_string(convert(sl))$HyperdocUtilities)
            search_operations(f1)$BRI

        filter_constructors(cl : List(SY), ari_f : ifT, sig_f : sfT
                           ) : List(SY) ==
            res : List(SY) := []
            for c in cl repeat
                sig := constructor_signature(c)$BRI
                -- FIXME
                null?(sig) => iterate
                not(ari_f(#destruct(sig) - 1)) => iterate
                sl := cons(convert('Mapping), destruct(sig))
                cs := constructor_to_string(convert(sl))$HyperdocUtilities
                not(sig_f(cs)) => iterate
                res := cons(c, res)
            reverse!(res)

        do_detailed_search1(page : HyperdocPage, fl : List(SY),
                            np : String, ari_f : ifT, sig_f : sfT
                           ) : Con_res ==
            -- print(message("do_detailed_search1")$OutputForm)$OutputForm
            ru := search_constructors(np, 'k)$BRI
            ru case Err_ind => ru
            res0 := ru::Split_rec
            res1 : Split_rec := [[], [], []]
            if first(fl) = 'category then
                res1.categories := filter_constructors(res0.categories,
                                                       ari_f, sig_f)
                fl := rest(fl)
            if not(empty?(fl)) and first(fl) = 'domain then
                res1.domains := filter_constructors(res0.domains,
                                                    ari_f, sig_f)
                fl := rest(fl)
            if not(empty?(fl)) and first(fl) = 'package then
                res1.packages := filter_constructors(res0.packages,
                                                     ari_f, sig_f)
                fl := rest(fl)
            res1

        get_input_field(page : HyperdocPage, key : SY) : String ==
            resu := input_string(page, key)
            resu case String => resu
            error "get_input_field: no field value"

        pat_err := ["Error", "Invalid pattern"]::Err_ind

        get_string_filter(s : String) : Union(sfT, Err_ind) ==
            tf : (String) -> Boolean := s +-> true
            s = "*" or s = "" => tf
            s := downcase(s)$BRI
            pu := parse_pattern(s, true)$LogicalRegularExpressionMatch
            pu case "failed" => pat_err
            pa := pu@LMA
            (s1 : String) : Boolean +-> do_match(pa, downcase(s1)$BRI)

        ord_zero ==> 48

        char_to_dig(c : Character) : Union(Integer, "failed") ==
            i := ord(c)
            i < ord_zero => "failed"
            i := i - ord_zero
            i < 10 => i
            "failed"

        str_to_num(s : String) : Union(Integer, "failed") ==
            res : Integer := 0
            #s = 0 => "failed"
            for i in 1..#s repeat
                u1 := char_to_dig(s(i))
                u1 case "failed" => return "failed"
                res := 10*res + u1::Integer
            res

        gen_num_filter(s : String) : Union(ifT, Err_ind) ==
            tf : (Integer) -> Boolean := i +-> true
            s = "*" or s = "" => tf
            (k := position(char("-"), s)) > 0 =>
                s1 := s(1..(k-1))
                s2 := s((k+1)..#s)
                u1 := str_to_num(s1)
                u1 case "failed" => pat_err
                i1 := u1::Integer
                u1 := str_to_num(s2)
                u1 case "failed" => pat_err
                i2 := u1::Integer
                i2 < i1 => pat_err
                (i : Integer) : Boolean +-> (i1 <= i and i <= i2)
            op : SY :=
                s(1) = char("<") =>
                    #s < 2 => return pat_err
                    s(2) = char("=") =>
                        s := s(3..#s)
                        'le
                    s := s(2..#s)
                    'lt
                s(1) = char(">") =>
                    #s < 2 => return pat_err
                    s(2) = char("=") =>
                        s := s(3..#s)
                        'ge
                    s := s(2..#s)
                    'gt
                'eq
            u1 := str_to_num(s)
            u1 case "failed" => pat_err
            u := u1::Integer
            op = 'eq => (i : Integer) : Boolean +-> i = u
            op = 'le => (i : Integer) : Boolean +-> i <= u
            op = 'lt => (i : Integer) : Boolean +-> i < u
            op = 'ge => (i : Integer) : Boolean +-> i >= u
            op = 'gt => (i : Integer) : Boolean +-> i > u
            error "unimplemented"

        do_detailed_search(page : HyperdocPage, data : SE) : Void ==
            which : SY := button_value(page, 'which)
            name := get_input_field(page, 'name)
            nargs := get_input_field(page, 'nargs)
            sig := get_input_field(page, 'sig)
            -- print(message("do_detailed_search")$OutputForm)$OutputForm
            -- print(which::OutputForm)$OutputForm
            -- print([name, nargs, sig]::OutputForm)$OutputForm
            nfu := get_string_filter(name)
            nfu case Err_ind => error_page(nfu)
            nam_f := nfu::sfT
            afu := gen_num_filter(nargs)
            afu case Err_ind => error_page(afu)
            ari_f := afu::ifT
            sfu := get_string_filter(sig)
            sfu case Err_ind => error_page(sfu)
            sig_f := sfu::sfT
            which = 'ops  =>
                opl := do_detailed_operation_search(page, nam_f, ari_f, sig_f)
                empty?(opl) => empty_result("operation", "", "")
                show_op_lines(opl)
            not(which = 'cons) =>
                error_page2("Error",
                            ["Choose either constructors or operations"])
            fl : List(SY) := []
            if button_on?(page, 'cats) then
                fl := ['category]
            if button_on?(page, 'doms) then
                fl := cons('domain, fl)
            if button_on?(page, 'paks) then
                fl := cons('package, fl)
            -- if button_on?(page, 'defs) then
            --    fl := cons('default, fl)
            fl := reverse!(fl)
            empty?(fl) =>
                error_page2("Error",
                            ["Nothing choosen"])
            desc : String :=
                #fl ~= 1 => "constructor"
                sf1 := first(fl)
                sf1 = 'default => "default package"
                string(sf1)
            resu := do_detailed_search1(page, fl, name, ari_f, sig_f)
            resu case Err_ind => error_page(resu)
            res1 := resu::Split_rec
            show_split_constructors(res1, desc, "")

        show_ops_from(page : HyperdocPage, lst : Op_lst
                     ) : Void ==
            conform := get_property(page, 'conform)
            domname := get_property(page, 'domname)
            kind := string(get_property(page, 'kind))
            if kind = "category" then
                domname := convert([])
            if not(null?(domname)) then
                lst := simp_ops_conditions(lst, conform, domname)$BRI
            conform :=
                null?(domname) => conform
                domname
            exp_part : String :=
                exp_con?(conform) => ""
                "unexposed "
            from_part : String :=
                sl :=
                    null?(domname) =>
                        con_to_strings(conform, true, [])
                    con_to_strings(domname, domname, true, true, [])
                concat(reverse!(sl))
            -- print(from_part::OutputForm)$OutputForm
            title : List(String) := [" from ", exp_part, kind, " {\em ",
                                     from_part, "}"]
            set_property(page, 'fromHeading, title pretend SE)
            set_op_lst(page, lst)
            show_op_lines3(page, lst, 'names)

        do_op_from(op : String, con : String) : Void ==
            page := new(empty())$HyperdocPage
            ops := op::SY
            con_sym := con::SY
            con_form := constructor_form(con_sym)$BRI
            set_property(page, 'conform, con_form)
            kind_sym : SY := get_db_info(con_sym, 'CONSTRUCTORKIND)
            set_property(page, 'kind, convert(string(kind_sym)))
            opl : Op_lst := operations(con_form, convert([]))$BRI
            opl := [rec for rec in opl | rec.name = ops]
            show_ops_from(page, opl)

        get_input_string(page : HyperdocPage, label : SY) : String ==
            resu := input_string(page, label)
            resu case String => resu
            ""

        get_input_area(page : HyperdocPage, narg : Integer
                      ) : List(String) ==
            pvars : List(SY) := _$PatternVariableList$Lisp
            res : List(String) :=
                [get_input_string(page, vi) for i in 1..narg for vi in pvars]
            -- print(message("get_input_area")$OutputForm)$OutputForm
            -- print(res::OutputForm)$OutputForm
            res

        input_area_changed?(page : HyperdocPage, narg : Integer
                           ) : Boolean ==
            res : Boolean := get_input_area(page, narg) ~=
                (get_property(page, 'inputAreaList) pretend List(String))
            -- print(message("input_area_changed?")$OutputForm)$OutputForm
            -- print(res::OutputForm)$OutputForm
            res

        constructor_operations_page(page : HyperdocPage) : Void ==
            conform := get_property(page, 'conform)
            name := symbol(car(conform))
            kind := get_constructor_kind(name)
            narg := #conform - 1
            u := get_property(page, 'domname)
            -- print(message("in constructor_operations_page"
            --              )$OutputForm)$OutputForm
            -- print(u::OutputForm)$OutputForm
            domu : Union(SE, Err_ind) :=
                list?(u) and not(null?(u)) and
                      (u1 := car(u); is_symbol?(u1, name)) and
                    not(input_area_changed?(page, narg)) => u
                get_evalable_constructor_form(page, name)
            domu case Err_ind => error_page(domu)
            domname := domu@SE
            set_property(page, 'domname, domname)
            title1 : String :=
                not(null?(domname)) => constructor_to_string(domname)
                -- constring
                string(name)
            title : List(String) := [capitalize(string(kind)),
                " {\sf ", title1, "}"]
            set_property(page, 'heading, title pretend SE)
            use_args? := not(null?(domname))
            domname :=
                not(null?(domname)) => domname
                conform
            -- print(message("constructor_operations_page calling operations"
            --             )$OutputForm)$OutputForm
            opl : Op_lst := operations(conform, domname)$BRI
            show_ops_from(page, opl)

        unparse_args(op : SY, args : List(SE)) : List(String) ==
            res : List(String) := []
            co_sig : List(Boolean) := rest(get_db_info(op, 'COSIG))
            for k? in co_sig for arg in args for k in 1.. repeat
                r1 := con_arg_to_strings(k?, op, [], arg, convert([]), k,
                                         false, [])
                res := cons(concat(reverse!(r1)), res)
            reverse!(res)

        -- con_page should always get valid form, that is name should
        -- be constructor name and number of arguments should match.
        -- Arguments should be valid expression of appripriate type
        -- or (possibly fake) variable names.
        con_page(form : SE) : Void ==
            atom?(form) => error "con_page: invalid form"
            lc := destruct(form)
            -- print(lc::OutputForm)$OutputForm
            op := symbol(first(lc))
            args := unparse_args(op, rest(lc))
            -- lc1 := destruct(constructor_form(op)$BRI)
            -- if #lc1 > #lc then
            --    lc := lc1
            -- print(message("unparsed")$OutputForm)$OutputForm
            -- print(message("calling constructor_page")$OutputForm)$OutputForm
            constructor_page(op, lc, args)

        show_cons_kinds_filter(page : HyperdocPage, data : SE
                              ) : Void ==
            -- print(message("show_cons_kinds_filter")$OutputForm)$OutputForm
            (kind, lst) := destruct(data)
            set_con_lst(page, lst pretend Cond_con_lst)
            show_cons(page, get_property(page, 'exclusion))

        select_con(page : HyperdocPage, data : SE) : Void ==
            i := integer(data)
            lst := get_con_lst(page)
            form := (lst(i + 1)).form
            con_page(convert([car(form)]))

        make_string_box(width : Integer, name : SY) : SE ==
            e1 : List(SE) := [convert(width), convert("*"),
                              convert(name), convert('EM)]
            convert([convert('bcStrings), convert(e1)])

        make_text_item(txt : String) : SE ==
            CONS('text, txt)$Lisp

        add_string_box(txt : String, width : Integer, name : SY,
                       acc : List(SE)) : List(SE) ==
            acc := cons(make_text_item(txt), acc)
            cons(make_string_box(width, name), acc)

        add_button(sname : SY, tname : String, acc : List(SE)
                  ) : List(SE) ==
            l1 : List(SE) := [convert(1@Integer), convert(sname)]
            l1 := [convert('bcButtons), convert(l1)]
            acc := cons(convert(l1), acc)
            cons(make_text_item(concat([" {\em ", tname, "} "])), acc)

        detailed_search(pat : String) : Void ==
            page := new(empty())$HyperdocPage
            add_title(page, ["Detailed Search with Options"])
            add_to_description(page, "\beginscroll ")
            add_list_to(page, [
                "Select what you want to search for, then click on "
                      "{\em Search} below.",
                        "\horizontalline{}\newline{}"])
            l1 := [make_text_item("\newline\vspace{1}\newline ")]
            lo : List(SE) := [convert("\tab{3}{\em Operations}"),
                              convert(l1), convert('ops)]
            l1 := [make_text_item("\tab{17}")]
            l1 := add_button('cats, "categories", l1)
            l1 := add_button('doms, "domains", l1)
            l1 := add_button('paks, "packages", l1)
            -- l1 := add_button('defs, "defaults", l1)
            l1 := cons(make_text_item("\newline\tab{3}"), l1)
            l1 := add_string_box("name", 14, 'name, l1)
            l1 := add_string_box(" \#args", 4, 'nargs, l1)
            l1 := add_string_box("signature", 14, 'sig, l1)
            l1 := cons(make_text_item("\vspace{1}\newline "), l1)
            l1 := reverse!(l1)
            lc : List(SE) := [convert("\tab{3}{\em Constructors}"),
                              convert(l1), convert('cons)]
            l1 := [convert('bcRadioButtons), convert('which),
                   convert(lo), convert(lc)]
            add_to(page, [convert(l1)])
            add_to_description(page, "\vspace{1}\newline\centerline{ ")
            l1 := [convert("\fbox{Search}"), convert(""),
                   convert('generalSearchDo), convert([])]
            add_to(page, [convert([convert('bcLinks), convert(l1)])])
            add_to_description(page, "}")
            add_to_description(page, "\endscroll")
            show(page)

        exports_page(page : HyperdocPage) : Void ==
            conform := get_property(page, 'conform)
            name := symbol(car(conform))
            kind := get_constructor_kind(name)
            domu := get_evalable_constructor_form(page, name)
            domu case Err_ind => error_page(domu)
            domname : SE := domu
            set_property(page, 'domname, domname)
            con_string : String :=
                null?(domname) => string(name)
                constructor_to_string(domname)
            form_l :=
                null?(domname) => conform
                domname
            data := exports(form_l)$BRI
            con_lst := data.cats
            op_lst := data.ops
            if not(null?(domname)) then
                n_lst : Cond_con_lst := []
                for e1 in con_lst repeat
                    p1 := e1.condition
                    n_p1 : SE := simpHasPred(p1)$Lisp
                    n_e1 : Cond_rec :=
                        p1 = n_p1 => e1
                        [e1.form, n_p1]
                    n_lst := cons(n_e1, n_lst)
                con_lst := reverse!(n_lst)
                no_lst : Op_lst := []
                for rec in op_lst repeat
                    n_sdl := []$List(Sig_doc)
                    for sd in rec.sdl repeat
                        p1 := sd.condition
                        n_p1 : SE := simpHasPred(p1)$Lisp
                        null?(n_p1) => iterate
                        n_sd : Sig_doc :=
                            p1 = n_p1 => sd
                            [sd.signature, n_p1, sd.origin, sd.documentation]
                        n_sdl := cons(n_sd, n_sdl)
                    if not empty?(n_sdl) then
                        no_lst := cons([rec.name, n_sdl], no_lst)
                op_lst := reverse!(no_lst)
            page := new(copy_property_list(get_property_list(page)))
            cnt := #con_lst + count_ops(op_lst)
            prefix : List(String) := [get_count_str(cnt),
                   (cnt > 1 => "exports"; "export")]
            title := concat(prefix, [" of ", string(kind),  " {\sf ",
                       con_string, "}"])
            add_title(page, title)
            star? := ref(false)$Reference(Boolean)
            add_to_description(page, "\beginscroll")
            begin_menu(page)
            if not(empty?(con_lst)) then
                lnk1 : List(SE) := [con_lst pretend SE, convert('names)]
                add_op_link0(page, 'bcLinks, menu_button, 'dbShowCons1,
                             convert(lnk1))
                add_to_description(page, "\tab{2}")
                add_to_description(page, "All attributes and operations from:")
                name_con_table(page, con_lst, false, star?)
            if not(empty?(op_lst)) then
                if not(empty?(con_lst)) then
                    add_to_description(page, "\vspace{1}\newline{}")
                display_exported_ops(page, op_lst)
            end_menu(page)
            add_to_description(page, "\endscroll")
            show(page)

        contains_formal(se : SE) : Boolean ==
            -- FIXME
            true

        k_arg_page(page: HyperdocPage, arg : SE) : Void ==
            -- print(message("k_arg_page")$OutputForm)$OutputForm
            -- print(arg::OutputForm)$OutputForm
            i : Integer := -1
            conform : SE :=
                list?(arg) =>
                    al := destruct(arg)
                    i := integer(al(2))
                    arg := al(1)
                    lst := get_con_lst(page)
                    form2 := (lst(i + 1)).form
                    constructor_form(symbol(car(form2)))$BRI
                get_property(page, 'conform)
            op := symbol(car(conform))
            args := destruct(cdr(conform))
            -- print(conform::OutputForm)$OutputForm
            n := position(arg, args)
            -- print(n::OutputForm)$OutputForm
            source : List(SE) :=
                rest(destruct(constructor_signature(op)$BRI))
            arg_n : SE := source(n)
            arg_form := sublis_formal(args, arg_n)$BRI
            dom_name : SE :=
                i < 0 => get_property(page, 'domname)
                convert([])
            arg_dom : SE :=
                not(null?(dom_name)) =>
                    sublis_formal(rest(destruct(dom_name)), arg_n)$BRI
                empty?(args) => arg_n
                contains_formal(arg_n) => convert([])
                arg_n
            descendants := domains(arg_form, arg_dom)$BRI
            page := new(copy_property_list(get_property_list(page)))
            set_property(page, 'conform, conform)
            set_property(page, 'domname, convert([]))
            set_con_lst(page, descendants)
            rank : String :=
                n > 5 => concat(convert(n)@String, "-th")
                ["first", "second", "third", "fourth", "fifth"](n)
            set_property(page, 'rank, convert(rank))
            set_property(page, 'thing, convert("argument"))
            show_cons(page, 'names)

        get_builtin_opl(c : SY, orig : SE) : Op_lst ==
            opl0 : List(SE) := GET(c, 'documentation)$Lisp
            res : Op_lst := []
            tc := true pretend SE
            for r0 in opl0 repeat
                rl0 := destruct(r0)
                name := symbol(first(rl0))
                -- fix change made by Shoe translator
                if name = "CASE"::SY then
                    name := "case"::SY
                sdl : List(Sig_doc) := []
                for s0 in rest(rl0) repeat
                    sl0 := destruct(s0)
                    sig := first(sl0)
                    doc := string(sl0(2))
                    sdl := cons([sig, tc, orig, doc]$Sig_doc, sdl)
                sdl := reverse!(sdl)
                res := cons([name, sdl]$Op_rec, res)
            reverse!(res)

        builtin_operations(c : SY) : Void ==
            -- print(message("builtin_operations")$OutputForm)$OutputForm
            -- print(c::OutputForm)$OutputForm
            con_form := constructor_form(c)$BRI
            opl := get_builtin_opl(c, con_form)
            page := new(empty())$HyperdocPage
            set_property(page, 'conform, con_form)
            set_property(page, 'kind, convert("domain"))
            show_ops_from(page, opl)

        do_search(pat : String, tag : SY, desc : String) : Void ==
            -- print(message("do_search")$OutputForm)$OutputForm
            pat := trim_pattern(pat)
            tag = 'aok => gen_search0(pat, false)
            tag = 'det =>
                detailed_search(pat)
            tag = 'doc => doc_search0(pat)
            tag = 'gen => gen_search0(pat, true)
            tag = 'o => operation_search(pat)
            tag = 'oPageFrom => do_op_from(pat, desc)
            constructor_search(pat, tag, desc)

        show_spad_type_error(s: String) : Void ==
            msg : List(String) := [s, "is not a valid constructor name"]
            error_page2("Error", msg)

        show_spad_type(s : String) : Void ==
            cnu : Union(SY, "failed") := find_symbol(s)$Lisp
            cnu case "failed" => show_spad_type_error(s)
            name := cnu@SY
            constructor_name?(name)$BRI =>
                con_page(convert([convert(name)]))
            show_spad_type_error(s)

        Gloss_rec ==> Record(term : String, description : String)
        gloss_lst : List(Gloss_rec) := []
        gloss_valid : Boolean := false

        load_gloss() : Void ==
            kfn : String := concat(_$spadroot$Lisp, "/algebra/glosskey.text")
            dfn : String := concat(_$spadroot$Lisp, "/algebra/glossdef.text")
            kf := open(kfn::FileName, "input")$TextFile
            df := open(dfn::FileName, "input")$TextFile
            gl : List(Gloss_rec) := []
            repeat
                kl := readLineIfCan!(kf)
                kl case "failed" => break
                dl := readLine!(df)
                k := position(char_tick, kl)
                key := kl(1..(k - 1))
                k := position(char_tick, dl)
                desc := dl((k+1)..#dl)
                gl := cons([key, desc]$Gloss_rec, gl)
            close!(kf)
            close!(df)
            gloss_lst := reverse!(gl)
            gloss_valid := true

        do_gloss_page(s : String) : Void ==
            if s = "" then
                s := "*"
            s = "*" => downlink("GlossaryPage")
            pat := convert_pattern(s)$BRI
            pat case Err_ind => error_page(pat)
            if not(gloss_valid) then
                load_gloss()
            res : List(Gloss_rec) := []
            for gloss in gloss_lst repeat
                if do_match(pat, gloss.term)$BRI then
                    res := cons(gloss, res)
            res := reverse!(res)
            empty?(res) =>
                el : List(String) := ["\centerline{",
                    "No glossary items match {\em ", s, "}}"]
                error_page2("Sorry", el)
            page := new(empty())$HyperdocPage
            add_title(page, ["Glossary items matching {\em ", s, "}"])
            add_to_description(page, "\beginscroll\beginmenu")
            for gloss in res repeat
                add_list_to(page, [
                    "\item{\em \menuitemstyle{}}\tab{0}{\em ",
                      escape_if_needed(gloss.term), "} ", gloss.description])
            add_to_description(page, "\endmenu \endscroll\newline ")
            l1 : List(SE) := [convert("Search"), convert(""),
                              convert('htGlossSearch), convert([])]
            l1 := [convert('bcLinks), convert(l1)]
            add_to(page, [convert(l1)])
            add_to_description(page, " for glossary entry matching ")
            l1 := [convert(24), convert("*"), convert('filter),
                   convert('EM)]
            l1 := [convert('bcStrings), convert(l1)]
            add_to(page, [convert(l1)])
            show(page)

        do_gloss_search(page : HyperdocPage) : Void ==
            s := get_input_string(page, 'filter)
            do_gloss_page(s)

        cons_opts(page : HyperdocPage, tag : SY) : Void ==
            tag = 'ancestors =>
                ancestors_page(page)
            tag = 'children =>
                children_page(page)
            tag = 'dependents =>
                dependents_page(page)
            tag = 'descendents =>
                descendents_page(page)
            tag = 'domains =>
                domains_page(page)
            tag = 'exports =>
                exports_page(page)
            tag = 'operations => constructor_operations_page(page)
            tag = 'parents =>
                parents_page(page)
            tag = 'search_path => show_search_path(page)
            tag = 'users =>
                users_page(page)
            tag = 'uses =>
                uses_page(page)
            error "cons_opts: unimplemented"

        do_page_fun1(page : HyperdocPage, tag : SY,
                    data : SE) : Void ==
            tag = 'cons_opts => cons_opts(page, symbol(data))
            tag = 'dbChooseDomainOp => choose_domain_op(page, integer(data))
            tag = 'dbSelectCon => select_con(page, data)
            tag = 'dbShowCons => show_cons(page, data)
            tag = 'dbShowCons1 =>
                show_constructors2(page, car(data) pretend Cond_con_lst,
                          symbol(car(cdr(data))), exposed_only?)
            tag = 'dbShowConsKindsFilter => show_cons_kinds_filter(page, data)
            tag = 'dbShowOps => show_ops(page, data)
            tag = 'htGlossSearch => do_gloss_search(page)
            tag = 'htFilterPage => do_filter(page, data)
            tag = 'generalSearchDo =>
                do_detailed_search(page, data)
            tag = 'genSearchSayJump =>
                gen_search_jump(page, data)
            tag = 'grepSearchJump => do_search_jump(page)
            tag = 'kArgPage =>
                k_arg_page(page, data)
            tag = 'kxPage =>
                downlink(string(data))
            tag = 'repeatSearch => repeat_search(page, not(null?(data)))
            tag = 'showConstruct =>
                show_it(page, data, get_reg_list(page)::Save_rec)
            tag = 'showDoc =>
                show_it(page, data, get_doc_list(page))
            error "do_page_fun1: unimplemented"

        do_gen_fun1(tag : SY, data : SE) : Void ==
            tag = 'conPage => con_page(data)
            tag = 'conPageChoose => con_page_choose(data)
            tag = 'dbSpecialOperations => builtin_operations(symbol(data))
            tag = 'htGloss => do_gloss_page(string(data))
            tag = 'spadType => show_spad_type(string(data))
            error "do_gen_fun1: unimplemented"
